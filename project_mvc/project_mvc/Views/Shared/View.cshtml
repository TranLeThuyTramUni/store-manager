         ========================================================= -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/Scripts/view.js"></script>
    @*<script src="~/Scripts/cart.js"></script>*@

<script>
        (function () {
            const header = document.getElementById("hsHeader");
            const floatingStack = document.getElementById("hsFloatingStack");
            const backToTopBtn = document.getElementById("btnBackToTop");
            const zaloBtn = document.getElementById("btnZaloChat");
            const messengerBtn = document.getElementById("btnMessengerChat");
            const botBtn = document.getElementById("btnBotChat");
            const botBadge = document.getElementById("botBadge");
            const nav = document.getElementById("hsMainNav");
            const newsletterBtn = document.getElementById("newsletterBtn");
            const newsletterEmail = document.getElementById("newsletterEmail");
            const cartBadge = document.getElementById("cartBadge");
            const chatShell = document.getElementById("hsChatbotShell");
            const chatForm = document.getElementById("chatboiForm");
            const chatInput = document.getElementById("chatboiInput");
            const chatMessages = document.getElementById("chatboiMessages");
            const chatSuggestions = document.getElementById("chatboiSuggestions");
            const chatCloseBtn = document.getElementById("chatboiClose");
            const chatStatus = document.getElementById("chatboiStatus");
            const chatTyping = document.getElementById("chatboiTyping");

            const suggestionPrompts = [
                "Giao hàng mất bao lâu ở TP.HCM?",
                "Chính sách đổi trả mỹ phẩm như thế nào?",
                "Da dầu mụn nên dùng sữa rửa mặt nào của The Face Shop?",
                "Da nhạy cảm có dùng được dưỡng ẩm không?",
                "Combo skincare sáng tối gợi ý giúp mình",
                "Hiện đang có khuyến mãi hoặc freeship không?",
                "Son kem mịn lì nào đang hot nhất?",
                "Làm sao kiểm tra hàng chính hãng?",
                "Có giao quốc tế không?",
                "Tư vấn quà tặng cho nữ 25 tuổi",
                "Điểm tích lũy và ưu đãi thành viên hoạt động ra sao?",
                "Cách chọn kem chống nắng phù hợp từng loại da"
            ];

            // Dữ liệu câu trả lời đã được chuyển sang ChatBot API; fallback chỉ trả về thông báo mặc định khi offline.
            const fallbackAnswers = [];

            const defaultAnswer = "Mình đã ghi nhận câu hỏi và sẽ hỗ trợ nhanh nhất. Bạn có thể mô tả rõ hơn về da, nhu cầu hoặc mã đơn để mình tư vấn chi tiết.";

            let hasShownWelcome = false;
            let hasRenderedSuggestions = false;

            // Chỉ lấy nút Back To Top cho scroll
            // Không lấy toàn bộ fabs nữa
            // const fabs = floatingStack ? floatingStack.querySelectorAll(".hs-fab") : [];

            // --- Scroll handling: header shrink + only back-to-top fades ---
            const onScroll = function () {
                const y = window.pageYOffset || document.documentElement.scrollTop || 0;

                // Thu nhỏ header khi cuộn
                if (header) {
                    if (y > 24) {
                        header.classList.add("is-scrolled");
                    } else {
                        header.classList.remove("is-scrolled");
                    }
                }

                // Chỉ nút lên đầu trang được bật/tắt theo cuộn
                if (backToTopBtn) {
                    if (y > 260) {
                        backToTopBtn.classList.add("is-visible");
                    } else {
                        backToTopBtn.classList.remove("is-visible");
                    }
                }
            };

            window.addEventListener("scroll", onScroll, { passive: true });
            onScroll();


            // --- Back to top ---
            if (backToTopBtn) {
                backToTopBtn.addEventListener("click", function () {
                    window.scrollTo({ top: 0, behavior: "smooth" });
                });
            }

            const renderSuggestions = function () {
                if (!chatSuggestions || hasRenderedSuggestions) return;
                suggestionPrompts.forEach(function (prompt) {
                    const chip = document.createElement("button");
                    chip.type = "button";
                    chip.className = "hs-chatbot-chip";
                    chip.textContent = prompt;
                    chip.addEventListener("click", function () {
                        openChatbot(true);
                        sendMessage(prompt);
                    });
                    chatSuggestions.appendChild(chip);
                });
                hasRenderedSuggestions = true;
            };

            const appendMessage = function (role, text) {
                if (!chatMessages) return;
                const bubble = document.createElement("div");
                bubble.className = "hs-chatbot-message " + (role === "user" ? "is-user" : "is-bot");
                bubble.textContent = text;
                chatMessages.appendChild(bubble);
                chatMessages.scrollTop = chatMessages.scrollHeight;
            };

            const showSuggestions = function () {
                if (chatSuggestions) {
                    chatSuggestions.classList.remove("is-hidden");
                }
            };

            const hideSuggestions = function () {
                if (chatSuggestions) {
                    chatSuggestions.classList.add("is-hidden");
                }
            };

            const toggleTyping = function (visible) {
                if (!chatTyping) return;
                chatTyping.classList.toggle("is-visible", visible);
            };

            const setStatus = function (text) {
                if (chatStatus) {
                    chatStatus.textContent = text;
                }
            };

            const fallbackFromLibrary = function (question) {
                const lower = (question || "").toLowerCase();
                const matched = fallbackAnswers.find(function (item) {
                    return item.keywords.some(function (keyword) { return lower.indexOf(keyword) >= 0; });
                });
                return matched ? matched.answer : defaultAnswer;
            };

            const ensureWelcome = function () {
                if (hasShownWelcome) return;
                appendMessage("bot", "Xin chào! Mình là trợ lý ảo dùng ChatBoiAPI của The Face Shop.");
                appendMessage("bot", "Bạn có thể hỏi về sản phẩm, quy trình chăm sóc da, thanh toán, giao hàng hoặc khuyến mãi. Chọn nhanh gợi ý bên dưới hoặc nhập câu hỏi!");
                hasShownWelcome = true;
            };

            const openChatbot = function (focusInput) {
                if (chatShell) {
                    chatShell.classList.add("is-open");
                }
                if (botBadge) {
                    botBadge.style.display = "none";
                }
                ensureWelcome();
                showSuggestions();
                renderSuggestions();
                if (focusInput && chatInput) {
                    chatInput.focus();
                }
            };

            const closeChatbot = function () {
                if (chatShell) {
                    chatShell.classList.remove("is-open");
                }
            };

            async function sendToChatboiApi(question) {
                const payload = {
                    message: question
                };

                const response = await fetch("/api/chatbot/ask", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload)
                });

                if (!response.ok) {
                    throw new Error("ChatBot API trả về lỗi");
                }

                const data = await response.json();
                if (data?.success && data?.answer) return data.answer;
                if (data?.answer) return data.answer;
                if (data?.message) return data.message;

                return fallbackFromLibrary(question);
            }

            const sendMessage = async function (message) {
                const text = (message || "").trim();
                if (!text) return;

                ensureWelcome();
                hideSuggestions();
                appendMessage("user", text);
                if (chatInput) {
                    chatInput.value = "";
                }

                toggleTyping(true);
                setStatus("Đang gửi đến ChatBot Web API...");

                let reply = "";
                try {
                    reply = await sendToChatboiApi(text);
                    setStatus("Đã phản hồi từ ChatBot Web API");
                } catch (error) {
                    reply = fallbackFromLibrary(text);
                    setStatus("Đang dùng thư viện câu trả lời nhanh (offline)");
                }

                toggleTyping(false);
                appendMessage("bot", reply);
            };

            // --- Chat actions (thay link Zalo/Messenger bằng của bạn) ---
            if (zaloBtn) {
                zaloBtn.addEventListener("click", function () {
                    // Mở Zalo OA hoặc số điện thoại
                    window.open("https://zalo.me/0377599221", "_blank");
                });
            }

            if (messengerBtn) {
                messengerBtn.addEventListener("click", function () {
                    // Mở Messenger fanpage
                    window.open("https://m.me/thefaceshopvn", "_blank");
                });
            }

            if (botBtn) {
                botBtn.addEventListener("click", function () {
                    openChatbot(true);
                });
            }

            if (chatCloseBtn) {
                chatCloseBtn.addEventListener("click", function () {
                    closeChatbot();
                });
            }

            if (chatForm) {
                chatForm.addEventListener("submit", function (event) {
                    event.preventDefault();
                    sendMessage(chatInput ? chatInput.value : "");
                });
            }

            if (chatInput) {
                chatInput.addEventListener("keydown", function (event) {
                    if (event.key === "Enter" && !event.shiftKey) {
                        event.preventDefault();
                        sendMessage(chatInput.value);
                    }
                });
            }

            // --- Active nav link theo URL hiện tại ---
            if (nav) {
                const links = nav.querySelectorAll(".hs-nav-link");
                const path = (window.location.pathname || "").toLowerCase();

                links.forEach(function (link) {
                    link.classList.remove("is-active");
                });

                if (path.indexOf("/sanpham") >= 0) {
                    nav.querySelector('[data-nav-key="product"]')?.classList.add("is-active");
                } else if (path.indexOf("/camnanglamdep") >= 0) {
                    nav.querySelector('[data-nav-key="blog"]')?.classList.add("is-active");
                } else if (path.indexOf("/hotrokhachhang") >= 0) {
                    nav.querySelector('[data-nav-key="support"]')?.classList.add("is-active");
                } else {
                    nav.querySelector('[data-nav-key="home"]')?.classList.add("is-active");
                }
            }

            // --- Đăng ký newsletter (demo) ---
            if (newsletterBtn && newsletterEmail) {
                newsletterBtn.addEventListener("click", function () {
                    const value = (newsletterEmail.value || "").trim();
                    if (!value) {
                        alert("Vui lòng nhập email để đăng ký nhận bản tin.");
                        newsletterEmail.focus();
                        return;
                    }

                    // Ở đây bạn có thể gọi AJAX / API thực để lưu email
                    alert("Cảm ơn bạn đã đăng ký! Chúng tôi sẽ gửi ưu đãi sớm nhất đến " + value);
                    newsletterEmail.value = "";
                });
            }

            // --- Đồng bộ badge giỏ (nếu cart.js có cập nhật localStorage/sessionStorage) ---
            try {
                const storedCount = window.localStorage ? parseInt(localStorage.getItem("cart-count") || "0", 10) : 0;
                if (cartBadge && !Number.isNaN(storedCount) && storedCount >= 0) {
                    cartBadge.textContent = storedCount.toString();
                }
            } catch (e) {
                // bỏ qua lỗi
            }
        })();
        // Gọi 1 lần khi load trang để lấy số lượng trong giỏ
    document.addEventListener("DOMContentLoaded", function () {
        fetch('@Url.Action("CartData", "GioHang")', {
            method: 'GET',
            credentials: 'same-origin'
        })
            .then(function (res) { return res.json(); })
            .then(function (data) {
                if (data && data.success) {
                    var badge = document.getElementById('cartBadge');
                    if (badge) {
                        badge.textContent = data.totalQuantity || 0;
                    }
                }
            })
            .catch(function (err) {
                console.error('CartData error:', err);
            });
    });

    // Hàm tiện dùng lại khi thêm/xoá/cập nhật giỏ bằng AJAX
    function refreshCartBadgeFromData(data) {
        try {
            var badge = document.getElementById('cartBadge');
            if (!badge) return;
            if (data && typeof data.totalQuantity !== 'undefined') {
                badge.textContent = data.totalQuantity;
            }
        } catch (e) {
            console.error(e);
        }
    }
</script>

    @RenderSection("scripts", required: false)
</body>
</html>

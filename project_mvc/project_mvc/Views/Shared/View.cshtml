@{
    Layout = null;
}
@using project_mvc.Models
@{
    int cartCount = 0;

    // Lấy giỏ hàng từ Session
    var cart = Session["Cart"] as CartViewModel;

    if (cart != null && cart.Items != null)
    {
        cartCount = cart.TotalQuantity;   // tổng số lượng sản phẩm
                                          // hoặc: cart.Items.Count        // tổng số dòng sản phẩm
    }
}
<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title • The Face Shop.vn</title>

    <!-- Bootstrap core -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    @RenderSection("Styles", required: false)

    <style>
        /* =========================================================
           THE FACE SHOP – GLOBAL THEME
           ========================================================= */

        :root {
            /* brand */
            --hs-primary: #10b981;
            --hs-primary-soft: rgba(16, 185, 129, 0.1);
            --hs-primary-soft-2: rgba(16, 185, 129, 0.08);
            --hs-primary-dark: #059669;
            --hs-primary-darker: #047857;
            /* accent */
            --hs-accent-pink: #f973b7;
            --hs-accent-yellow: #facc15;
            /* neutral */
            --hs-bg-body: #f8fafc;
            --hs-bg-elevated: #ffffff;
            --hs-bg-subtle: #f1f5f9;
            --hs-border-subtle: #e2e8f0;
            --hs-border-soft: rgba(148, 163, 184, 0.4);
            /* text */
            --hs-text-main: #1a1d23;
            --hs-text-soft: #1a1d23;
            --hs-text-muted: #1a1d23;
            /* shadow */
            --hs-shadow-soft: 0 18px 45px rgba(15, 23, 42, 0.10);
            --hs-shadow-tiny: 0 4px 14px rgba(15, 23, 42, 0.06);
            /* layout */
            --hs-header-height: 84px;
            --hs-header-height-scrolled: 68px;
            --hs-max-width: 1320px;
            --hs-radius-lg: 1.25rem;
            --hs-radius-xl: 1.75rem;
            --hs-radius-pill: 999px;
            /* z-index */
            --hs-z-header: 1040;
            --hs-z-floating: 1045;
            /* transition */
            --hs-ease-smooth: cubic-bezier(0.17, 0.67, 0.36, 0.99);
        }

        html,
        body {
            height: 100%;
            scroll-behavior: smooth;

        }

        body {
            margin: 0;
            color: var(--hs-text-main);
            font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, "Apple Color Emoji", "Segoe UI Emoji";
            background:
                radial-gradient(circle at top left, #fef3c7 0, transparent 55%),
                radial-gradient(circle at bottom right, #e0f2fe 0, transparent 55%),
                linear-gradient(to bottom, #f9fafb, #f1f5f9);
            background-attachment: fixed;
        }

        /* ---- Utility spacing & typography ---- */

        .hs-container {
            max-width: var(--hs-max-width);
            margin-inline: auto;
            padding-inline: 1.25rem;
        }

        .text-soft {
            color: var(--hs-text-soft) !important;
        }

        .text-muted-soft {
            color: var(--hs-text-muted) !important;
        }

        .fw-semibold {
            font-weight: 600 !important;
        }

        .rounded-xl {
            border-radius: var(--hs-radius-xl) !important;
        }

        .rounded-lg-2 {
            border-radius: var(--hs-radius-lg) !important;
        }

        .rounded-pill-2 {
            border-radius: var(--hs-radius-pill) !important;
        }

        .shadow-soft {
            box-shadow: var(--hs-shadow-soft);
        }

        .shadow-tiny {
            box-shadow: var(--hs-shadow-tiny);
        }

        .bg-subtle {
            background-color: var(--hs-bg-subtle) !important;
        }

        .bg-elevated {
            background-color: var(--hs-bg-elevated) !important;
        }

        .border-subtle {
            border-color: var(--hs-border-subtle) !important;
        }

        .text-truncate-2 {
            display: -webkit-box;
            -webkit-box-orient: vertical;
            -webkit-line-clamp: 2;
            overflow: hidden;
        }

        /* =========================================================
           TOP ANNOUNCEMENT & UTIL BAR
           ========================================================= */

        .hs-top-announcement {
            position: relative;
            z-index: var(--hs-z-header);
            background:
                radial-gradient(circle at left top, #f973b7 0, #fb7185 22%, transparent 60%),
                radial-gradient(circle at right bottom, #facc15 0, #fde68a 35%, transparent 65%),
                linear-gradient(90deg, #f973b7, #facc15);
            color: #1f2933;
            font-size: .92rem;
        }

        .hs-top-announcement-inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: .55rem 0;
        }

        .hs-top-pill {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            padding: .3rem .9rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.26);
            font-weight: 600;
            white-space: nowrap;
        }

        .hs-top-link {
            color: #1f2933;
            font-weight: 600;
            text-decoration: none;
            padding-inline: .65rem;
        }

            .hs-top-link:hover {
                text-decoration: underline;
            }

        .hs-top-marquee {
            display: inline-flex;
            align-items: center;
            gap: .75rem;
            white-space: nowrap;
            overflow: hidden;
            position: relative;
        }

        .hs-top-marquee span {
            animation: hs-marquee 16s linear infinite;
            display: inline-block;
        }

        @@keyframes hs-marquee {
            0% {
                transform: translateX(0%);
            }

            100% {
                transform: translateX(-50%);
            }
        }

        .hs-top-utils {
            display: flex;
            align-items: center;
            gap: .5rem;
            font-size: .85rem;
        }

        .hs-top-utils a {
            color: #111827;
            text-decoration: none;
            opacity: .95;
        }

            .hs-top-utils a:hover {
                opacity: 1;
                text-decoration: underline;
            }

        @* compact on mobile *@
        @@media (max-width: 768px) {
            .hs-top-announcement-inner {
                flex-direction: column;
                align-items: flex-start;
            }

            .hs-top-marquee {
                width: 100%;
            }

            .hs-top-pill {
                font-size: .8rem;
            }

            .hs-top-utils {
                width: 100%;
                justify-content: space-between;
            }
        }

        /* =========================================================
           HEADER: GLASS STICKY BAR
           ========================================================= */

        .hs-header-shell {
            position: sticky;
            top: 0;
            z-index: var(--hs-z-header);
            backdrop-filter: blur(18px);
            background-color: rgba(248, 250, 252, 0.9);
            border-bottom: 1px solid rgba(226, 232, 240, 0.85);
            transition: all .22s var(--hs-ease-smooth);
        }

            .hs-header-shell.is-scrolled {
                background-color: rgba(255, 255, 255, 0.98);
                box-shadow: 0 15px 35px rgba(15, 23, 42, 0.08);
            }

        .hs-header {
            height: var(--hs-header-height);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1.5rem;
            transition: height .2s var(--hs-ease-smooth), padding .2s var(--hs-ease-smooth);
        }

        .hs-header-shell.is-scrolled .hs-header {
            height: var(--hs-header-height-scrolled);
        }

        .hs-brand {
            display: flex;
            align-items: center;
            gap: .75rem;
            text-decoration: none;
            color: inherit;
        }

        .hs-brand-logo {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: radial-gradient(circle at 25% 0, #22d3ee, #14b8a6 38%, #0f766e);
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 12px 32px rgba(45, 212, 191, 0.38);
            color: white;
        }

        .hs-brand-logo span {
            font-weight: 800;
            letter-spacing: .04em;
            font-size: .85rem;
        }

        .hs-brand-text {
            display: flex;
            flex-direction: column;
        }

        .hs-brand-name {
            font-size: 1.26rem;
            font-weight: 800;
            letter-spacing: .12em;
            text-transform: uppercase;
        }

        .hs-brand-sub {
            font-size: .78rem;
            color: var(--hs-text-soft);
            text-transform: uppercase;
            letter-spacing: .18em;
        }

        /* SEARCH BAR: chiếm toàn bộ khoảng trống giữa logo và action */
        .hs-search {
            flex: 1 1 auto; /* cho phép giãn theo flex */
            width: auto;
            max-width: none; /* KHÔNG giới hạn chiều rộng nữa */
        }


        .hs-search-form {
            display: flex;
            border-radius: 999px;
            background: linear-gradient(90deg, rgba(15, 23, 42, 0.12), rgba(15, 23, 42, 0.04));
            padding: 1px;
        }

        .hs-search-inner {
            display: flex;
            align-items: stretch;
            border-radius: inherit;
            background: rgba(15, 23, 42, 0.02);
            backdrop-filter: blur(20px);
        }

        .hs-search-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding-inline: .85rem;
            color: var(--hs-text-soft);
            font-size: 1rem;
        }

        .hs-search-input {
            border: 0;
            outline: 0;
            flex: 1;
            background: transparent;
            padding: .6rem .3rem;
            font-size: .95rem;
            color: var(--hs-text-main);
        }

            .hs-search-input::placeholder {
                color: var(--hs-text-muted);
            }

        .hs-search-right {
            display: flex;
            align-items: center;
            gap: .25rem;
            padding-right: .3rem;
        }

        .hs-search-key-hint {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: .25rem .55rem;
            border-radius: 999px;
            border: 1px solid rgba(148, 163, 184, .6);
            font-size: .7rem;
            color: var(--hs-text-muted);
            background-color: rgba(15, 23, 42, 0.02);
        }

        .hs-search-btn {
            border-radius: 999px;
            border: 0;
            padding: .45rem 1.25rem;
            font-size: .9rem;
            font-weight: 600;
            background: linear-gradient(135deg, var(--hs-primary), var(--hs-primary-dark));
            color: #ffffff;
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            box-shadow: 0 12px 25px rgba(34, 197, 94, 0.32);
            transition: transform .08s ease, box-shadow .08s ease, filter .08s ease;
        }

            .hs-search-btn:hover {
                filter: brightness(1.02);
                transform: translateY(-1px);
                box-shadow: 0 16px 35px rgba(34, 197, 94, 0.34);
            }

            .hs-search-btn:active {
                transform: translateY(0);
                box-shadow: 0 9px 18px rgba(34, 197, 94, 0.28);
            }

        /* ---- Header actions (login, cart, etc.) ---- */

        .hs-header-actions {
            display: flex;
            align-items: center;
            gap: .75rem;
        }

        .hs-header-icon-btn {
            position: relative;
            border-radius: 999px;
            border: 1px solid var(--hs-border-soft);
            background-color: rgba(255, 255, 255, 0.9);
            padding: .5rem .7rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: .35rem;
            font-size: .9rem;
            color: var(--hs-text-main);
            text-decoration: none;
            transition: border-color .18s ease, box-shadow .18s ease, transform .08s ease, background .18s ease;
        }

            .hs-header-icon-btn:hover {
                border-color: var(--hs-primary);
                background-color: #ffffff;
                box-shadow: 0 8px 22px rgba(15, 23, 42, 0.12);
                transform: translateY(-1px);
            }

            .hs-header-icon-btn i {
                font-size: 1rem;
            }

        .hs-header-user-dropdown .dropdown-toggle {
            border-radius: 999px;
            border: 1px solid var(--hs-border-soft);
            background-color: rgba(255, 255, 255, 0.9);
            padding: .5rem .9rem;
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            font-size: .9rem;
            text-decoration: none;
            color: var(--hs-text-main);
        }

            .hs-header-user-dropdown .dropdown-toggle:hover {
                border-color: var(--hs-primary);
                background-color: #ffffff;
                box-shadow: 0 8px 22px rgba(15, 23, 42, 0.12);
            }

        .hs-cart-btn {
            border-radius: 999px;
            border: 1px solid rgba(22, 163, 74, 0.55);
            padding: .5rem .8rem;
            background: rgba(22, 163, 74, 0.06);
            color: #14532d;
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            font-size: .9rem;
        }

            .hs-cart-btn i {
                font-size: 1.05rem;
            }

        .hs-cart-count {
            min-width: 1.25rem;
            height: 1.25rem;
            border-radius: 999px;
            font-size: .7rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #ffffff;
            background: linear-gradient(135deg, #dc2626, #b91c1c);
        }

        /* ---- Mobile header tweaks ---- */

        .hs-header-toggle {
            display: none;
        }

        @@media (max-width: 992px) {
            .hs-header {
                gap: 1rem;
            }

            .hs-brand-name {
                font-size: 1rem;
            }

            .hs-brand-sub {
                display: none;
            }

            .hs-search {
                display: none;
            }

            .hs-header-toggle {
                display: inline-flex;
                border-radius: 999px;
                border: 1px solid var(--hs-border-soft);
                padding: .45rem .7rem;
                background-color: rgba(255, 255, 255, 0.9);
                font-size: 1.1rem;
                align-items: center;
                justify-content: center;
            }

            .hs-header-actions {
                gap: .5rem;
            }

            .hs-header-icon-btn span {
                display: none;
            }
        }

        /* =========================================================
           CATEGORY NAV (MEGA-LIKE NAV)
           ========================================================= */

        .hs-nav-shell {
            border-top: 1px solid rgba(226, 232, 240, 0.9);
            border-bottom: 1px solid rgba(226, 232, 240, 0.9);
            background: radial-gradient(circle at top, #f9fafb 0, #ffffff 50%, #f8fafc 100%);
        }

        .hs-nav {
            display: flex;
            align-items: center;
            flex-wrap: nowrap;
            overflow-x: auto;
            gap: .15rem;
            padding: .6rem 0;
            scrollbar-width: thin;
        }

        .hs-nav-link {
            position: relative;
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            padding: .45rem .85rem;
            margin-inline: .05rem;
            border-radius: 999px;
            font-size: 1.0rem;
            font-weight: 500;
            color: var(--hs-text-soft);
            text-decoration: none;
            white-space: nowrap;
            transition: color .18s ease, background .18s ease, transform .08s ease;
        }

            .hs-nav-link span.hs-dot {
                width: 6px;
                height: 6px;
                border-radius: 999px;
                background-color: rgba(148, 163, 184, .65);
            }

            .hs-nav-link:hover {
                color: var(--hs-text-main);
                background-color: rgba(15, 23, 42, 0.04);
                transform: translateY(-1px);
            }

            .hs-nav-link.is-active {
                color: #0b1727;
                background: linear-gradient(135deg, var(--hs-primary-soft), rgba(56, 189, 248, 0.15));
                box-shadow: 0 8px 20px rgba(22, 163, 74, 0.16);
            }

                .hs-nav-link.is-active span.hs-dot {
                    background-image: linear-gradient(135deg, #22c55e, #14b8a6);
                }

        .hs-nav-sale {
            margin-left: auto;
        }

        .hs-nav-sale-pill {
            display: inline-flex;
            align-items: center;
            gap: .5rem;
            padding: .4rem .9rem;
            border-radius: 999px;
            background: linear-gradient(120deg, #f97316, #ef4444);
            color: #ffffff;
            font-size: .84rem;
            font-weight: 600;
            text-decoration: none;
        }

            .hs-nav-sale-pill span.badge {
                background-color: rgba(15, 23, 42, 0.98);
                font-size: .7rem;
                border-radius: 999px;
            }

        @@media (max-width: 768px) {
            .hs-nav-sale-pill {
                font-size: .8rem;
            }

            .hs-nav {
                padding-bottom: .75rem;
            }
        }

        /* =========================================================
           MAIN PAGE WRAPPER
           ========================================================= */

        .hs-page-wrapper {
            min-height: calc(100vh - 280px);
            padding-top: 1.5rem;
            padding-bottom: 3.5rem;
        }

        @@media (max-width: 768px) {
            .hs-page-wrapper {
                padding-top: 1rem;
                padding-bottom: 3rem;
            }
        }

        /* =========================================================
           NEWSLETTER STRIP (RE-DESIGNED)
           ========================================================= */

        .hs-newsletter-shell {
            padding: 3.5rem 0 2.5rem;
        }

        .hs-newsletter {
            position: relative;
            border-radius: 1.75rem;
            background:
                radial-gradient(circle at top left, rgba(45, 212, 191, 0.16) 0, transparent 55%),
                radial-gradient(circle at bottom right, rgba(248, 113, 113, 0.2) 0, transparent 55%),
                linear-gradient(120deg, #ecfdf5, #eff6ff);
            padding: 2rem 2.2rem;
            overflow: hidden;
        }

        .hs-newsletter::before {
            content: "";
            position: absolute;
            inset: -40%;
            background-image: radial-gradient(circle at top, rgba(148, 163, 184, 0.12) 0, transparent 50%);
            opacity: .7;
            pointer-events: none;
        }

        .hs-newsletter-main {
            position: relative;
            z-index: 1;
        }

        .hs-newsletter-title {
            font-size: 1.4rem;
            font-weight: 800;
            margin-bottom: .3rem;
        }

        .hs-newsletter-desc {
            font-size: .95rem;
            color: var(--hs-text-soft);
            margin-bottom: 1.25rem;
        }

        .hs-newsletter-form {
            display: flex;
            gap: .75rem;
            flex-wrap: wrap;
        }

        .hs-newsletter-form .form-control {
            border-radius: 999px;
            border: 1px solid rgba(148, 163, 184, 0.5);
            padding-inline: 1.1rem;
            min-width: 220px;
        }

            .hs-newsletter-form .form-control:focus {
                border-color: var(--hs-primary);
                box-shadow: 0 0 0 .15rem rgba(16, 185, 129, .2);
            }

        .hs-newsletter-btn {
            border-radius: 999px;
            border: 0;
            padding-inline: 1.5rem;
            font-weight: 600;
            font-size: .9rem;
            background: linear-gradient(135deg, #22c55e, #16a34a);
            color: #ffffff;
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            box-shadow: 0 8px 20px rgba(22, 163, 74, 0.32);
        }

            .hs-newsletter-btn:hover {
                filter: brightness(1.03);
            }

        .hs-newsletter-meta {
            margin-top: .7rem;
            font-size: .8rem;
            color: var(--hs-text-muted);
        }

        .hs-newsletter-meta a {
            color: var(--hs-text-soft);
            text-decoration: underline;
        }

        .hs-newsletter-badges {
            position: relative;
            z-index: 1;
            display: grid;
            gap: .75rem;
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .hs-service-chip {
            border-radius: 1rem;
            background-color: rgba(255, 255, 255, 0.9);
            border: 1px dashed rgba(148, 163, 184, 0.6);
            padding: .8rem .9rem;
            display: flex;
            align-items: center;
            gap: .75rem;
            font-size: .85rem;
        }

            .hs-service-chip-icon {
                width: 32px;
                height: 32px;
                border-radius: 999px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                background: rgba(16, 185, 129, 0.06);
                color: var(--hs-primary-darker);
            }

            .hs-service-chip-title {
                font-weight: 600;
            }

            .hs-service-chip-sub {
                font-size: .78rem;
                color: var(--hs-text-muted);
            }

        @@media (max-width: 992px) {
            .hs-newsletter {
                padding: 1.7rem 1.35rem;
            }

            .hs-newsletter-badges {
                margin-top: 1.5rem;
            }
        }

        @@media (max-width: 576px) {
            .hs-newsletter-form {
                flex-direction: column;
                align-items: stretch;
            }

            .hs-newsletter-form .form-control {
                width: 100%;
            }

            .hs-newsletter-btn {
                justify-content: center;
            }

            .hs-newsletter-badges {
                grid-template-columns: 1fr;
            }
        }

        /* =========================================================
           FOOTER – MODERN COLUMN FOOTER
           ========================================================= */

        .hs-footer-shell {
            border-top: 1px solid var(--hs-border-subtle);
            background: radial-gradient(circle at top right, rgba(226, 232, 240, .7) 0, transparent 55%), #f9fafb;
            padding-top: 2.75rem;
            padding-bottom: 2.2rem;
        }

        .hs-footer-brand {
            max-width: 320px;
        }

        .hs-footer-logo {
            height: 38px;
            margin-bottom: .9rem;
        }

        .hs-footer-desc {
            font-size: .9rem;
            color: var(--hs-text-soft);
        }

        .hs-footer-social {
            display: flex;
            flex-wrap: wrap;
            gap: .5rem;
            margin-top: 1rem;
        }

        .hs-footer-social a {
            border-radius: 999px;
            border: 1px solid rgba(148, 163, 184, 0.55);
            padding: .4rem .9rem;
            font-size: .85rem;
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            text-decoration: none;
            color: var(--hs-text-main);
            background-color: #ffffff;
        }

            .hs-footer-social a i {
                font-size: .9rem;
            }

            .hs-footer-social a:hover {
                border-color: var(--hs-primary);
                color: var(--hs-primary-darker);
            }

        .hs-footer-title {
            font-size: .95rem;
            font-weight: 700;
            margin-bottom: 1rem;
            text-transform: uppercase;
            letter-spacing: .06em;
            color: #020617;
        }

        .hs-footer-menu {
            list-style: none;
            margin: 0;
            padding: 0;
            font-size: .9rem;
        }

        .hs-footer-menu li + li {
            margin-top: .4rem;
        }

        .hs-footer-menu a {
            color: var(--hs-text-soft);
            text-decoration: none;
        }

            .hs-footer-menu a:hover {
                color: var(--hs-primary-darker);
                text-decoration: underline;
            }

        .hs-footer-apps {
            display: flex;
            flex-wrap: wrap;
            gap: .4rem;
        }

        .hs-footer-apps img {
            height: 38px;
            border-radius: .75rem;
            background-color: #0f172a;
        }

        .hs-footer-payments {
            display: flex;
            flex-wrap: wrap;
            gap: .5rem;
            align-items: center;
            margin-top: .75rem;
        }

        .hs-footer-bottom {
            border-top: 1px solid rgba(226, 232, 240, 0.9);
            margin-top: 2rem;
            padding-top: 1rem;
            font-size: .85rem;
            color: var(--hs-text-muted);
            display: flex;
            flex-wrap: wrap;
            gap: .75rem;
            justify-content: space-between;
            align-items: center;
        }

        @@media (max-width: 768px) {
            .hs-footer-shell {
                padding-top: 2rem;
                padding-bottom: 1.6rem;
            }

            .hs-footer-bottom {
                flex-direction: column;
                align-items: flex-start;
            }
        }

        /* =========================================================
           OFFCANVAS CART CUSTOMIZATION
           ========================================================= */

        .offcanvas-cart {
            border-left: 1px solid var(--hs-border-subtle);
        }

        .offcanvas-cart .offcanvas-header {
            padding-top: 1rem;
            padding-bottom: .7rem;
        }

        .offcanvas-cart .offcanvas-title {
            font-size: 1rem;
            font-weight: 700;
        }

        .cart-item-thumb {
            width: 56px;
            height: 56px;
            border-radius: 1rem;
            object-fit: cover;
        }

        .cart-item-title {
            font-size: .9rem;
            font-weight: 500;
        }

        .cart-item-meta {
            font-size: .8rem;
            color: var(--hs-text-muted);
        }

        .cart-item-price {
            font-weight: 600;
            font-size: .9rem;
        }

        .cart-summary {
            border-top: 1px dashed var(--hs-border-subtle);
            padding-top: .75rem;
            margin-top: .75rem;
        }

        /* =========================================================
           FLOATING ACTIONS: BACK TO TOP + CHAT STACK
           ========================================================= */

        .hs-floating-stack {
            position: fixed;
            right: 2.25rem;
            bottom: 1.25rem;
            z-index: var(--hs-z-floating);
            display: flex;
            flex-direction: column;
            gap: .55rem;
            align-items: flex-end;
        }

        .hs-fab {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            border: 0;
            padding: .7rem .9rem;
            background-color: var(--hs-bg-elevated);
            color: var(--hs-text-main);
            box-shadow: 0 10px 30px rgba(15, 23, 42, 0.16);
            cursor: pointer;
            font-size: .92rem;
            gap: .5rem;
            text-decoration: none;
            min-width: 46px;
            position: relative;
            overflow: hidden;
            transition: transform .12s ease, box-shadow .12s ease, background .12s ease, opacity .12s ease;
            opacity: 0;
            pointer-events: none;
        }

            .hs-fab.is-visible {
                opacity: 1;
                pointer-events: auto;
            }

            .hs-fab i {
                font-size: 1.1rem;
            }

            .hs-fab-label {
                white-space: nowrap;
                font-size: .85rem;
                font-weight: 500;
            }

            .hs-fab:hover {
                transform: translateY(-1px);
                box-shadow: 0 16px 35px rgba(15, 23, 42, 0.23);
            }

        .hs-fab--primary {
            background: linear-gradient(135deg, var(--hs-primary), var(--hs-primary-dark));
            color: #ffffff;
        }

        .hs-fab--zalo {
            background: #ffffff;
            color: #0f172a;
        }

            .hs-fab--zalo::before {
                content: "";
                position: absolute;
                inset: 0;
                background: radial-gradient(circle at top left, rgba(56, 189, 248, 0.25), transparent 60%);
                opacity: .4;
            }

        .hs-fab--messenger {
            background: #ffffff;
            color: #0f172a;
        }

            .hs-fab--messenger::before {
                content: "";
                position: absolute;
                inset: 0;
                background: radial-gradient(circle at top right, rgba(96, 165, 250, 0.25), transparent 60%);
                opacity: .4;
            }

        .hs-fab--bot {
            background: #0f172a;
            color: #e5e7eb;
        }

            .hs-fab--bot .hs-fab-label {
                color: #e5e7eb;
            }

        .hs-fab-badge {
            position: absolute;
            top: -4px;
            right: -3px;
            min-width: 18px;
            height: 18px;
            border-radius: 999px;
            background: #ef4444;
            color: #ffffff;
            font-size: .65rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 0 3px #ffffff;
        }

        @@media (max-width: 576px) {
            .hs-floating-stack {
                right: .75rem;
                bottom: .75rem;
            }

            .hs-fab {
                padding-inline: .8rem;
            }

            .hs-fab-label {
                display: none;
            }
        }

        /* =========================================================
           MISC. ANIMATIONS & HELPERS
           ========================================================= */

        .hs-pill-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: .15rem .55rem;
            border-radius: 999px;
            font-size: .7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .12em;
            background-color: rgba(15, 23, 42, 0.06);
            color: #0f172a;
        }

        .hs-pill-badge--live {
            background-color: rgba(248, 113, 113, 0.15);
            color: #b91c1c;
        }

        .fade-in-up {
            opacity: 0;
            transform: translateY(8px);
            animation: fadeInUp .4s ease forwards;
        }

        @@keyframes fadeInUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Placeholder for content spacing inside views if needed */
        .hs-page-inner-section {
            margin-bottom: 2rem;
        }
        /* ==== FAB: cùng kích thước, chỉ icon ==== */
        /* Khối chung cho tất cả nút nổi */
        .hs-fab {
            width: 62px; /* kích thước nút */
            height: 62px;
            border-radius: 50%; /* tròn */
            padding: 0; /* bỏ padding ngang */
            justify-content: center; /* icon nằm giữa */
            min-width: 52px; /* tránh bị kéo to */
        }

        /* Chỉ hiện icon, ẩn chữ label */
        .hs-fab-label {
            display: none !important;
        }

        /* Icon to hơn tí cho đẹp */
        .hs-fab i {
            font-size: 1.3rem;
        }

        /* Màu nền từng nút (tuỳ bạn chỉnh cho “đẹp” hơn) */

        /* Back to top – xanh lá thương hiệu */
        .hs-fab--primary {
            background: radial-gradient(circle at 30% 0, #bbf7d0 0, #22c55e 45%, #16a34a 80%);
            color: #ffffff;
        }

        /* Zalo – xanh dương */
        .hs-fab--zalo {
            background: radial-gradient(circle at 30% 0, #e0f2fe 0, #60a5fa 45%, #2563eb 80%);
            color: #ffffff;
        }

        /* Messenger – tím xanh */
        .hs-fab--messenger {
            background: radial-gradient(circle at 30% 0, #ede9fe 0, #a855f7 45%, #7c3aed 80%);
            color: #ffffff;
        }

        /* Bot chat – đen/xám sang */
        .hs-fab--bot {
            background: radial-gradient(circle at 30% 0, #4b5563 0, #020617 70%);
            color: #e5e7eb;
        }

            .hs-fab--bot .hs-fab-label {
                display: none !important;
            }

        /* Badge nhỏ trên nút bot vẫn giữ nguyên */
        .hs-fab-badge {
            top: -4px;
            right: -3px;
        }


        /* Khung tìm kiếm */
        .hs-search-inner {
            display: flex;
            align-items: center;
            background: #ffffff;
            padding: 0 .75rem 0 .85rem;
            border-radius: 999px;
            border: 1px solid rgba(148,163,184,0.35);
            box-shadow: 0 8px 22px rgba(15,23,42,0.06);
            transition: 0.25s ease;
        }

            /* Hiệu ứng focus */
            .hs-search-inner:focus-within {
                border-color: #10b981;
                box-shadow: 0 0 0 4px rgba(16,185,129,0.18);
            }

        /* Icon trái */
        .hs-search-icon {
            color: #64748b;
            font-size: 1rem;
            margin-right: .5rem;
        }

        /* Input */
        .hs-search-input {
            flex: 1;
            border: none;
            outline: none;
            background: transparent;
            padding: .65rem .5rem;
            font-size: .95rem;
            color: #0f172a;
        }

            .hs-search-input::placeholder {
                color: #94a3b8;
            }

        /* Nút tìm kiếm */
        .hs-search-btn {
            border: none;
            outline: none;
            background: #10b981;
            padding: .55rem .9rem;
            border-radius: 999px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1rem;
            transition: 0.2s;
        }

            .hs-search-btn:hover {
                background: #0d9467;
            }

        /* === FIX CHIỀU DÀI THANH SEARCH === */
        .hs-header {
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: 1.5rem;
        }

        .hs-search {
            flex: 1 1 auto;
            width: 100%;
            max-width: none;
        }

        /* Khung search full width */
        .hs-search-form,
        .hs-search-inner {
            width: 100%;
        }
        /* Header: chia 3 khối brand – search – actions cân đối */
        .hs-header {
            display: flex;
            align-items: center;
            justify-content: space-between; /* lại chia đều 2 bên */
            gap: 1.5rem;
        }

        /* Khối search: chỉ chiếm lớn nhưng không full hết */
        .hs-search {
            flex: 1 1 auto; /* cho phép giãn */
            max-width: 720px; /* đủ dài, không đè actions */
            width: 100%;
        }

        /* Khung search tự full trong .hs-search */
        .hs-search-form,
        .hs-search-inner {
            width: 100%;
        }

        .hs-nav-shell {
            border: none !important;
        }
        .hs-top-utils {
            white-space: nowrap; /* Không xuống dòng */
            flex-shrink: 0; /* Không bị ép nhỏ */
        }
        .hs-top-announcement-inner > div:first-child {
            min-width: 0; /* Cho phép co lại */
            flex-shrink: 1; /* Co được */
        }

        /* ===== HEADER PINK GRADIENT ===== */
        .hs-header-shell {
            background: linear-gradient(180deg, #ffeef5, #ffe1ec) !important;
            border-bottom: 1px solid #f8cbd8 !important;
        }

            .hs-header-shell.is-scrolled {
                background: linear-gradient(180deg, #ffe8f1, #ffd6e7) !important;
            }

        .hs-nav-shell {
            background: linear-gradient(180deg, #ffeef5, #ffe1ec) !important;
            border-top: 1px solid #f8cbd8 !important;
            border-bottom: 1px solid #f8cbd8 !important;
        }
        .hs-nav-shell {
            border: none !important;
        }
        .hs-top-announcement {
            background: linear-gradient(90deg, #ffc6db 0%, #ff9fbd 50%, #ff82af 100%) !important;
            color: #ffffff;
        }
        /* ==========================================
   FOOTER PINK GRADIENT – SOFT PASTEL VERSION
   ========================================== */
        .hs-footer-shell {
            background: linear-gradient( 90deg, #ffe6f0 0%, /* hồng cực nhẹ */
            #ffd3e4 50%, /* pastel mềm */
            #ffbed7 100% /* hồng nhạt đẹp */
            ) !important;
            color: #4a0f25 !important;
            border-top: none !important;
        }

            /* Text trong footer */
            .hs-footer-shell p,
            .hs-footer-shell a,
            .hs-footer-shell li,
            .hs-footer-shell div {
                color: #4a0f25 !important;
            }

            /* Tiêu đề cột */
            .hs-footer-shell .hs-footer-title {
                color: #4a0f25 !important;
                font-weight: 700;
            }

            /* Hover link */
            .hs-footer-shell a:hover {
                color: #ffffff !important;
                text-decoration: underline;
            }

            /* Border dưới */
            .hs-footer-shell .hs-footer-bottom {
                border-top: 1px solid rgba(255, 255, 255, 0.45) !important;
            }

            /* Nút social */
            .hs-footer-shell .hs-footer-social a {
                background: rgba(255, 255, 255, 0.38) !important;
                border-color: rgba(255, 255, 255, 0.55) !important;
                color: #4a0f25 !important;
            }

                .hs-footer-shell .hs-footer-social a:hover {
                    background: rgba(255, 255, 255, 0.78) !important;
                }

            /* Icon / badge không đổi màu */
            .hs-footer-shell img {
                filter: none !important;
            }


        /* =========================================================
   CHATBOT (CHATBOIAPI) PANEL
   ========================================================= */

        .hs-chatbot-shell {
            position: fixed;
            right: 1.25rem;
            bottom: 5.75rem;
            width: 380px;
            max-height: 78vh;
            display: flex;
            flex-direction: column;
            background: var(--hs-bg-elevated);
            border: 1px solid var(--hs-border-subtle);
            box-shadow: var(--hs-shadow-soft);
            border-radius: 1.25rem;
            overflow: hidden;
            transform: translateY(24px);
            opacity: 0;
            pointer-events: none;
            transition: all .22s var(--hs-ease-smooth);
            z-index: calc(var(--hs-z-floating) + 5);
        }

            .hs-chatbot-shell.is-open {
                transform: translateY(0);
                opacity: 1;
                pointer-events: auto;
            }

        .hs-chatbot-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: .9rem 1.1rem;
            background: linear-gradient(135deg, rgba(16,185,129,0.1), rgba(4,120,87,0.08));
            border-bottom: 1px solid rgba(16, 185, 129, 0.2);
        }

        .hs-chatbot-title {
            font-weight: 800;
            font-size: 1rem;
            letter-spacing: .05em;
            text-transform: uppercase;
        }

        .hs-chatbot-status {
            font-size: .85rem;
            color: var(--hs-text-muted);
        }

        .hs-chatbot-close {
            border: 0;
            background: rgba(15, 23, 42, 0.06);
            width: 38px;
            height: 38px;
            border-radius: 12px;
            color: var(--hs-text-main);
        }

            .hs-chatbot-close:hover {
                background: rgba(16, 185, 129, 0.15);
                color: var(--hs-primary-darker);
            }

        .hs-chatbot-messages {
            padding: 1rem;
            flex: 1;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: .75rem;
            background: linear-gradient(180deg, rgba(16,185,129,0.03), transparent);
        }

        .hs-chatbot-message {
            max-width: 90%;
            padding: .75rem .9rem;
            border-radius: 1rem;
            font-size: .93rem;
            box-shadow: var(--hs-shadow-tiny);
            line-height: 1.5;
            white-space: pre-wrap;
        }

            .hs-chatbot-message.is-user {
                margin-left: auto;
                background: linear-gradient(135deg, var(--hs-primary), var(--hs-primary-dark));
                color: #ffffff;
                border-bottom-right-radius: .3rem;
            }

            .hs-chatbot-message.is-bot {
                margin-right: auto;
                background: #ffffff;
                border: 1px solid var(--hs-border-soft);
                color: var(--hs-text-main);
            }

        .hs-chatbot-typing {
            display: none;
            padding: 0 1rem 1rem;
            color: var(--hs-text-muted);
            font-size: .9rem;
        }

            .hs-chatbot-typing.is-visible {
                display: flex;
                gap: .35rem;
                align-items: center;
            }

            .hs-chatbot-typing span {
                width: 8px;
                height: 8px;
                background: var(--hs-primary);
                border-radius: 50%;
                display: inline-block;
                animation: hs-bounce 1.2s infinite ease-in-out;
            }

                .hs-chatbot-typing span:nth-child(2) {
                    animation-delay: .15s;
                }

                .hs-chatbot-typing span:nth-child(3) {
                    animation-delay: .3s;
                }

        .hs-chatbot-suggestions {
            padding: 0 1rem .5rem;
            display: flex;
            flex-wrap: wrap;
            gap: .5rem;
        }

            .hs-chatbot-suggestions.is-hidden {
                display: none;
            }

        .hs-chatbot-chip {
            border: 1px solid var(--hs-border-subtle);
            padding: .35rem .7rem;
            border-radius: 999px;
            background: rgba(15, 23, 42, 0.02);
            color: var(--hs-text-main);
            font-size: .86rem;
            cursor: pointer;
            transition: all .18s ease;
        }

            .hs-chatbot-chip:hover {
                border-color: var(--hs-primary);
                background: rgba(16, 185, 129, 0.1);
                color: var(--hs-primary-darker);
            }

        .hs-chatbot-input {
            display: flex;
            align-items: center;
            gap: .5rem;
            padding: .9rem 1rem 1rem;
            border-top: 1px solid var(--hs-border-subtle);
            background: rgba(255, 255, 255, 0.98);
        }

            .hs-chatbot-input input {
                flex: 1;
                border: 1px solid var(--hs-border-subtle);
                border-radius: .9rem;
                padding: .65rem .9rem;
                font-size: .95rem;
            }

                .hs-chatbot-input input:focus {
                    outline: 2px solid rgba(16, 185, 129, 0.25);
                    border-color: var(--hs-primary);
                }

            .hs-chatbot-input button {
                border: 0;
                border-radius: .9rem;
                padding: .65rem 1rem;
                background: linear-gradient(135deg, var(--hs-primary), var(--hs-primary-dark));
                color: #ffffff;
                font-weight: 700;
                display: inline-flex;
                align-items: center;
                gap: .4rem;
                box-shadow: var(--hs-shadow-tiny);
            }

                .hs-chatbot-input button:hover {
                    filter: brightness(0.98);
                }

        .hs-chatbot-note {
            font-size: .82rem;
            color: var(--hs-text-muted);
            padding: 0 1rem .75rem;
        }

        @@keyframes hs-bounce {
            0%, 80%, 100% {
                transform: scale(0);
                opacity: .6;
            }

            40% {
                transform: scale(1);
                opacity: 1;
            }
        }

        @@media (max-width: 768px) {
            .hs-chatbot-shell {
                width: calc(100% - 1.5rem);
                right: .75rem;
                left: .75rem;
                bottom: 5.5rem;
                max-height: 82vh;
            }

            .hs-chatbot-message {
                max-width: 100%;
            }
        }


    </style>
</head>

<body data-img-root="@Url.Content("~/images/")">
    @if (TempData["NewsletterSuccess"] != null)
    {
        <div class="alert alert-success text-center m-0">
            @TempData["NewsletterSuccess"]
        </div>
    }
    @if (TempData["NewsletterError"] != null)
    {
        <div class="alert alert-danger text-center m-0">
            @TempData["NewsletterError"]
        </div>
    }
    <!-- =========================================================
         TOP ANNOUNCEMENT BAR
         ========================================================= -->
    <div class="hs-top-announcement">
        <div class="hs-container">
            <div class="hs-top-announcement-inner">
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <div class="hs-top-pill">
                        <span>🎀 20.10 – ĐÓN DEAL YÊU 🎀</span>
                        <span class="d-none d-md-inline">Tỏa sắc cùng nàng</span>
                    </div>
                    <div class="hs-top-marquee d-none d-md-inline-flex">
                        <span>Giảm đến 50% • Extra voucher • Freeship đơn từ 299K • Quà độc quyền hội viên</span>
                        <span>- Trang web được nhóm TheFaceShop xây dựng</span>
                    </div>
                </div>
                <div class="hs-top-utils">
                    <a href="mailto:cs.vn@thefaceshop.com">
                        <i class="fa-regular fa-envelope me-1"></i> Hỗ trợ: cs.vn@thefaceshop.com
                    </a>
                    <span class="d-none d-sm-inline text-muted-soft">|</span>
                    <a href="@Url.Action("HoTroKhachHang","HoTroKhachHang")" class="d-none d-sm-inline">
                        <i class="fa-regular fa-circle-question me-1"></i> FAQs &amp; CSKH
                    </a>
                    <span class="d-none d-sm-inline text-muted-soft">|</span>
                    <a href="#" class="d-none d-sm-inline">
                        <img src="https://flagcdn.com/w20/vn.png" alt="VN" class="me-1" /> VN
                    </a>
                    <a href="#" class="d-none d-sm-inline">
                        <img src="https://flagcdn.com/w20/id.png" alt="ID" class="me-1" /> ID
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- =========================================================
         GLASS HEADER
         ========================================================= -->
    <header class="hs-header-shell" id="hsHeader">
        <div class="hs-container">
            <div class="hs-header">
                <!-- Brand -->
                <a href="@Url.Action("About","Home")" class="hs-brand">
                    <div class="hs-brand-text">
                        <div class="hs-brand-name">THE FACE SHOP</div>
                        <div class="hs-brand-sub">beauty &amp; skincare</div>
                    </div>
                </a>

                <!-- Search (desktop) -->
                <!-- SEARCH BAR (dùng chung desktop + mobile) -->
                <div class="hs-search flex-grow-1">
                    <form method="get"
                          action="@Url.Action("ShowSP","SanPham")"
                          class="hs-search-form">

                        <div class="hs-search-inner">
                            <span class="hs-search-icon">
                                <i class="fa-solid fa-magnifying-glass"></i>
                            </span>

                            <input name="search"
                                   type="text"
                                   class="hs-search-input"
                                   value="@(Request["search"] ?? "")"
                                   placeholder="Tìm sản phẩm, thương hiệu, chủ đề làm đẹp..." />

                            <button type="submit" class="hs-search-btn">
                                <i class="fa-solid fa-magnifying-glass"></i>
                            </button>
                        </div>

                        @foreach (string k in Request.QueryString.AllKeys ?? new string[0])
                        {

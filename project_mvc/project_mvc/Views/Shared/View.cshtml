                        <input name="search"
                               type="text"
                               class="form-control border-start-0"
                               value="@(Request["search"] ?? "")"
                               placeholder="Tìm sản phẩm, thương hiệu, chủ đề..." />
                        <button class="btn btn-success" type="submit">
                            Tìm
                        </button>

                        @foreach (string k in Request.QueryString.AllKeys ?? new string[0])
                        {
                            if (!string.IsNullOrEmpty(k) && k != "search" && k != "page")
                            {
                                <input type="hidden" name="@k" value="@Request.QueryString[k]" />
                            }

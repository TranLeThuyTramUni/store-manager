@model project_mvc.Models.QuanLyDanhMucViewModel

@{
    ViewBag.Title = "Quản lý danh mục";
    Layout = "~/Views/Shared/layoutAdmin.cshtml";
    bool isEdit = ViewBag.IsEdit != null && (bool)ViewBag.IsEdit;
    int total = Model.DanhSach != null ? Model.DanhSach.Count() : 0;
}

@section Styles {
    <style>
        /* =========================
           PALETTE & BASE
        ========================== */
        :root {
            --hs-primary: #ec4899; /* hồng pastel */
            --hs-primary-soft: #fdf2f8;
            --hs-primary-strong: #db2777;
            --hs-border: #e5e7eb;
            --hs-bg-page: #f5f7fb;
            --hs-text-main: #111827;
            --hs-text-muted: #6b7280;
        }

        body {
            background-color: var(--hs-bg-page);
        }

        /* =========================
           HEADER
        ========================== */
        .page-header-box {
            background: linear-gradient(135deg, #f9a8d4 0%, #ec4899 45%, #db2777 100%);
            padding: 20px 22px;
            border-radius: 18px;
            color: #fff;
            margin-bottom: 22px;
            box-shadow: 0 8px 24px rgba(236, 72, 153, 0.28);
            position: relative;
            overflow: hidden;
        }

            .page-header-box::after {
                content: "";
                position: absolute;
                inset: 0;
                background: radial-gradient(circle at 0% 0%, rgba(255,255,255,.32) 0, transparent 55%), radial-gradient(circle at 100% 100%, rgba(251,113,133,.32) 0, transparent 60%);
                opacity: .7;
                pointer-events: none;
            }

        .page-header-inner {
            position: relative;
            z-index: 1;
        }

        .page-header-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 4px 10px;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.16);
            font-size: 0.78rem;
        }

            .page-header-badge i {
                font-size: 0.9rem;
            }

        .page-header-title {
            font-size: 1.4rem;
            font-weight: 700;
            letter-spacing: 0.02em;
            display: flex;
            align-items: center;
            gap: .65rem;
        }

            .page-header-title i {
                font-size: 1.3rem;
            }

        .page-header-sub {
            font-size: 0.9rem;
            opacity: 0.9;
            margin-top: 0.2rem;
        }

        .page-header-stat {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 4px 10px;
            border-radius: 999px;
            background: rgba(15,23,42,.18);
            font-size: 0.8rem;
            margin-top: 0.6rem;
        }

            .page-header-stat span.badge {
                background: rgba(15,23,42,.9);
                border-radius: 999px;
            }

        /* =========================
           CARD FORM & TABLE
        ========================== */
        .form-card,
        .table-card {
            background: #ffffff;
            border-radius: 18px;
            padding: 18px 18px 20px;
            border: 1px solid rgba(148, 163, 184, 0.22);
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.06), 0 0 0 1px rgba(255, 255, 255, 0.5);
        }

        /* Sticky form bên trái */
        .sticky-form {
            position: sticky;
            top: 84px;
        }

        .form-card {
            position: relative;
            overflow: hidden;
        }

            .form-card::before {
                content: "";
                position: absolute;
                inset: 0;
                background: radial-gradient(circle at top right, rgba(236, 72, 153, 0.06), transparent 55%);
                pointer-events: none;
            }

        .form-card-inner {
            position: relative;
            z-index: 1;
        }

        .card-title-main {
            font-weight: 650;
            color: var(--hs-text-main);
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .card-title-main i {
                color: var(--hs-primary);
            }

        .card-sub-text {
            font-size: 0.8rem;
            color: var(--hs-text-muted);
        }

        .form-label {
            font-weight: 600;
            margin-bottom: 6px;
            color: var(--hs-text-main);
            font-size: 0.9rem;
        }

        .input-icon-group {
            position: relative;
        }

            .input-icon-group .bi {
                position: absolute;
                left: 10px;
                top: 50%;
                transform: translateY(-50%);
                font-size: .95rem;
                color: #9ca3af;
            }

            .input-icon-group .form-control {
                padding-left: 2.1rem;
            }

        .form-control,
        .form-select {
            border-radius: 10px !important;
            border-color: #e5e7eb;
            font-size: 0.9rem;
        }

            .form-control:focus,
            .form-select:focus {
                border-color: var(--hs-primary);
                box-shadow: 0 0 0 1px rgba(236, 72, 153, 0.25);
            }

        .form-hint {
            font-size: 0.8rem;
            color: var(--hs-text-muted);
        }

        .text-danger.small {
            font-size: 0.8rem;
        }

        /* Danh sách danh mục cuộn riêng (nếu nhiều) */
        .category-list-scroll {
            max-height: calc(100vh - 160px);
            overflow-y: auto;
            scrollbar-width: thin;
        }

            .category-list-scroll::-webkit-scrollbar {
                width: 6px;
            }

            .category-list-scroll::-webkit-scrollbar-track {
                background: #f3f4f6;
            }

            .category-list-scroll::-webkit-scrollbar-thumb {
                background: #cbd5f5;
                border-radius: 999px;
            }

        /* TABLE */
        .table-hover tbody tr {
            cursor: pointer;
            transition: background-color 0.12s ease, transform 0.05s ease;
        }

            .table-hover tbody tr:hover {
                background-color: #fdf2f8;
            }

        .table > :not(caption) > * > * {
            padding-top: 10px;
            padding-bottom: 10px;
        }

        .table thead th {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: var(--hs-text-muted);
            border-bottom: 1px solid #e5e7eb;
        }

        /* Cột STT chung */
        .table td.stt-cell {
            width: 44px;
            text-align: center;
            position: relative;
            font-weight: 500;
            font-size: 0.85rem;
            color: #6b7280;
        }

        /* Thanh ngang + đổi màu khi là dòng đang select */
        .table tr.row-selected td.stt-cell {
            color: #db2777; /* màu số */
            font-weight: 700;
        }

            .table tr.row-selected td.stt-cell::after {
                content: "";
                position: absolute;
                left: 6px;
                right: 6px;
                bottom: 3px;
                height: 3px;
                border-radius: 999px;
                background: linear-gradient(90deg, #fb7185, #ec4899, #db2777);
            }

        /* Buttons */
        .btn-primary {
            background: linear-gradient(135deg, var(--hs-primary), var(--hs-primary-strong));
            border: none;
            border-radius: 999px;
            padding: 7px 16px;
            font-weight: 600;
            font-size: 0.9rem;
        }

            .btn-primary:hover {
                background: linear-gradient(135deg, var(--hs-primary-strong), var(--hs-primary));
            }

        .btn-secondary {
            border-radius: 999px;
            font-size: 0.86rem;
        }

        .btn-icon-text i {
            margin-right: 4px;
        }

        .btn-action-full {
            padding: 6px 14px;
            border-radius: 12px;
            font-size: 0.85rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border: none;
            transition: 0.25s;
        }

        /* Sửa */
        .btn-edit-full {
            background: #fce7f3;
            color: #db2777;
        }

            .btn-edit-full:hover {
                background: #fbcfe8;
                box-shadow: 0 4px 10px rgba(219, 39, 119, 0.25);
            }

        /* Xóa */
        .btn-delete-full {
            background: #fee2e2;
            color: #dc2626;
        }

            .btn-delete-full:hover {
                background: #fecaca;
                box-shadow: 0 4px 10px rgba(220, 38, 38, 0.25);
            }

        /* Alert pill */
        .alert {
            border-radius: 999px;
            padding-top: 8px;
            padding-bottom: 8px;
            font-size: 0.86rem;
        }

            .alert i {
                margin-right: 6px;
            }

        .search-input {
            max-width: 260px;
        }

            .search-input .form-control {
                border-radius: 999px;
                padding-left: 2.1rem;
            }

            .search-input .bi-search {
                position: absolute;
                left: 10px;
                top: 50%;
                transform: translateY(-50%);
                font-size: 0.9rem;
                color: #9ca3af;
            }

        @@media (max-width: 991.98px) {
            .sticky-form {
                position: static;
            }

            .category-list-scroll {
                max-height: none;
            }

            .search-input {
                max-width: 100%;
                width: 100%;
            }
        }
    </style>
}

<div class="page-header-box">
    <div class="page-header-inner d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <div class="page-header-badge mb-1">
                <i class="bi bi-list-task"></i>
                <span>Quản lý danh mục sản phẩm</span>
            </div>
            <div class="page-header-title mb-1">
                <i class="bi bi-grid-3x3-gap-fill"></i>
                <span>Quản lý danh mục</span>
            </div>
            <div class="page-header-sub">
                Tạo, chỉnh sửa và sắp xếp danh mục sản phẩm trên cùng một giao diện.
            </div>
            <div class="page-header-stat">
                <i class="bi bi-grid-3x3-gap"></i>
                <span>Đang có</span>
                <span class="badge text-bg-light">@total danh mục</span>
            </div>
        </div>
    </div>
</div>

<!-- Thông báo -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4 align-items-start">
    <!-- Form thêm / sửa -->
    <div class="col-lg-4">
        <div class="form-card sticky-form">
            <div class="form-card-inner">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <h5 class="card-title-main mb-1">
                            @if (string.IsNullOrEmpty(Model.DanhMuc.MADANHMUC))
                            {
                                <span><i class="bi bi-plus-circle"></i> Thêm danh mục mới</span>
                            }
                            else
                            {
                                <span><i class="bi bi-pencil-square"></i> Sửa danh mục (@Model.DanhMuc.MADANHMUC)</span>
                            }
                        </h5>
                        <div class="card-sub-text">
                            Đặt mã và tên danh mục rõ ràng để dễ quản lý và hiển thị cho khách.
                        </div>
                    </div>
                </div>

                @using (Html.BeginForm("LuuDanhMuc", "QLDanhMucAdmin", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">Mã danh mục</label>
                        <div class="input-icon-group">
                            <i class="bi bi-upc-scan"></i>
                            @Html.TextBoxFor(m => m.DanhMuc.MADANHMUC, new
                            {
                                @class = "form-control form-control-sm",
                                placeholder = "VD: DM01",
                                required = "required",
                                @readonly = isEdit ? "readonly" : null
                            })
                        </div>
                        <div class="d-flex justify-content-between mt-1">
                            <span class="form-hint">Mã danh mục viết ngắn gọn, dễ nhớ.</span>
                            @if (isEdit)
                            {
                                <span class="text-muted" style="font-size:.78rem;">
                                    <i class="bi bi-info-circle"></i> Không thể đổi mã khi đang sửa.
                                </span>
                            }
                        </div>
                        @Html.ValidationMessageFor(m => m.DanhMuc.MADANHMUC, "", new { @class = "text-danger small" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tên danh mục</label>
                        <div class="input-icon-group">
                            <i class="bi bi-tag"></i>
                            @Html.TextBoxFor(m => m.DanhMuc.TENDANHMUC, new
                            {
                                @class = "form-control form-control-sm",
                                placeholder = "Nhập tên danh mục hiển thị cho khách",
                                required = "required"
                            })
                        </div>
                        @Html.ValidationMessageFor(m => m.DanhMuc.TENDANHMUC, "", new { @class = "text-danger small" })
                    </div>

                    <div class="d-flex justify-content-between gap-2 mt-3">
                        <a href="@Url.Action("QuanLyDanhMuc", "QLDanhMucAdmin", new { id = (string)null })"
                           class="btn btn-secondary btn-icon-text flex-fill">
                            <i class="bi bi-arrow-counterclockwise"></i> Làm mới
                        </a>

                        <button type="submit" class="btn btn-primary btn-icon-text flex-fill">
                            @if (string.IsNullOrEmpty(Model.DanhMuc.MADANHMUC))
                            {
                                <span><i class="bi bi-check-circle"></i> Thêm mới</span>
                            }
                            else
                            {
                                <span><i class="bi bi-save"></i> Lưu thay đổi</span>
                            }
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Bảng danh sách danh mục -->
    <div class="col-lg-8">
        <div class="table-card category-list-scroll">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                <div>
                    <h5 class="mb-1">
                        <i class="bi bi-list-ul me-1"></i> Danh sách danh mục
                    </h5>
                    <div class="card-sub-text">
                        Nhấp vào một dòng để chỉnh sửa nhanh danh mục đó.
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2 align-items-center">
                    <div class="position-relative search-input">
                        <i class="bi bi-search"></i>
                        <input type="text"
                               id="categorySearch"
                               class="form-control form-control-sm"
                               placeholder="Tìm theo mã / tên danh mục..." />
                    </div>

                    <a href="@Url.Action("QuanLyDanhMuc", "QLDanhMucAdmin", new { id = (string)null })"
                       class="btn btn-primary btn-icon-text btn-sm">
                        <i class="bi bi-plus-circle"></i> Thêm danh mục
                    </a>
                </div>
            </div>

            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Mã danh mục</th>
                        <th>Tên danh mục</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="categoryTableBody">
                    @if (Model.DanhSach != null && Model.DanhSach.Any())
                    {
                        int stt = 1;
                        foreach (var item in Model.DanhSach)
                        {
                            var isSelectedRow = Model.DanhMuc != null && item.MADANHMUC == Model.DanhMuc.MADANHMUC;

                            <tr class="@(isSelectedRow ? "row-selected" : "")"
                                data-code="@item.MADANHMUC"
                                data-name="@item.TENDANHMUC"
                                onclick="window.location='@Url.Action("QuanLyDanhMuc", "QLDanhMucAdmin", new { id = item.MADANHMUC })'">
                                <td class="stt-cell">@stt</td>
                                <td>
                                    <span class="fw-semibold">@item.MADANHMUC</span>
                                </td>
                                <td>@item.TENDANHMUC</td>
                                <td class="text-end">
                                    <a href="@Url.Action("QuanLyDanhMuc", "QLDanhMucAdmin", new { id = item.MADANHMUC })"
                                       class="btn-action-full btn-edit-full me-1"
                                       title="Sửa"
                                       onclick="event.stopPropagation();">
                                        <i class="bi bi-pencil-fill"></i> Sửa
                                    </a>

                                    @using (Html.BeginForm("XoaDanhMuc", "QLDanhMucAdmin", FormMethod.Post,
                                        new { onsubmit = "return confirm('Bạn chắc chắn muốn xóa danh mục này?');", @class = "d-inline" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        @Html.Hidden("id", item.MADANHMUC)
                                        <button type="submit"
                                                class="btn-action-full btn-delete-full"
                                                title="Xóa"
                                                onclick="event.stopPropagation();">
                                            <i class="bi bi-trash-fill"></i> Xóa
                                        </button>
                                    }
                                </td>
                            </tr>
                            stt++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">
                                <i class="bi bi-inboxes me-1"></i> Chưa có danh mục nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Lọc danh mục theo mã / tên (client-side)
        (function () {
            const input = document.getElementById('categorySearch');
            const rows = document.querySelectorAll('#categoryTableBody tr');

            if (!input || rows.length === 0) return;

            input.addEventListener('input', function () {
                const keyword = this.value.toLowerCase().trim();

                rows.forEach(row => {
                    const code = (row.getAttribute('data-code') || '').toLowerCase();
                    const name = (row.getAttribute('data-name') || '').toLowerCase();

                    if (!keyword || code.includes(keyword) || name.includes(keyword)) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });
            });
        })();
    </script>
}

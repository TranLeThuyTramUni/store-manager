@model project_mvc.Models.SanPham
@{
    ViewBag.Title = "Chi tiết";
    Layout = "~/Views/Shared/View.cshtml";   
}
<div class="container py-4">
    <h3 class="fw-bold mb-3">@Model.TENSP</h3>
    <img src="@Url.Content("~/images/" + (Model.HINHANH ?? "noimg.png"))"
         alt="@Model.TENSP" style="max-width:320px;border-radius:12px" />
    <p class="mt-3 mb-1"><strong>Giá:</strong> @String.Format("{0:N0}", Model.GIABAN) ₫</p>
    <p class="mb-1"><strong>Thương hiệu:</strong> @Model.THUONGHIEU</p>
    <p class="mb-1"><strong>Danh mục:</strong> @Model.TENDM</p>
    <p class="mb-4"><strong>Tồn kho:</strong> @Model.SOLUONG</p>
    <a class="btn btn-outline-secondary" href="@Url.Action("ShowSP","Home", new { categories = Model.MADM })">← Quay lại</a>
</div>

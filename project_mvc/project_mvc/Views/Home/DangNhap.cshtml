@{
    ViewBag.Title = "Đăng nhập";
    Layout = null; /* KHÔNG sử dụng Layout */
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title - THE FACE SHOP</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap + Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />

    <!-- Có thể giữ file riêng nếu bạn muốn -->
    <link rel="stylesheet" href="~/Content/style-auth.css" />

    <style>
        /* =====================================================================
           1. BIẾN MÀU – TÔNG HỒNG NHẸ, TINH TẾ
        ===================================================================== */
        :root {
            --hs-body-bg: #fdf2f8;
            --hs-body-bg-soft: #fef6fb;
            --hs-primary: #ec4899; /* Hồng chủ đạo */
            --hs-primary-soft: #fbcfe8; /* Hồng nhạt */
            --hs-primary-soft-2: #f9a8d4; /* Hồng pastel */
            --hs-primary-deep: #db2777; /* Hồng đậm */

            --hs-card-bg: rgba(255, 255, 255, 0.92);
            --hs-card-border: rgba(244, 114, 182, 0.25);
            --hs-text-main: #111827;
            --hs-text-muted: #6b7280;
            --hs-input-bg: rgba(255, 255, 255, 0.9);
            --hs-input-border: rgba(148, 163, 184, 0.65);
            --hs-input-border-focus: rgba(236, 72, 153, 0.9);
            --hs-shadow-soft: 0 22px 60px rgba(219, 39, 119, 0.22);
            --hs-shadow-subtle: 0 0 0 1px rgba(248, 250, 252, 0.85);
            --hs-radius-xl: 24px;
            --hs-radius-lg: 18px;
            --hs-radius-pill: 999px;
            --hs-transition-fast: 150ms ease-out;
            --hs-transition-normal: 220ms ease;
        }

        /* =====================================================================
           2. TỔNG THỂ BODY & NỀN
        ===================================================================== */
        html,
        body {
            height: 100%;
        }

        body {
            margin: 0;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            color: var(--hs-text-main);
            background:
                radial-gradient(circle at 0% 0%, rgba(251, 207, 232, 0.95) 0, transparent 52%),
                radial-gradient(circle at 100% 100%, rgba(219, 234, 254, 0.90) 0, transparent 58%),
                linear-gradient(135deg, var(--hs-body-bg) 0%, var(--hs-body-bg-soft) 100%);
            -webkit-font-smoothing: antialiased;
            text-rendering: optimizeLegibility;
        }

        /* Các vệt sáng nhẹ chạy nền */
        .bg-glow-bubble {
            position: fixed;
            border-radius: 999px;
            filter: blur(40px);
            opacity: 0.7;
            z-index: 0;
            pointer-events: none;
            transform: translate3d(0, 0, 0);
        }

        .bg-glow-bubble--pink {
            width: 260px;
            height: 260px;
            background: radial-gradient(circle, rgba(236, 72, 153, 0.65) 0, transparent 70%);
            top: -40px;
            right: -20px;
            animation: glowFloat1 13s ease-in-out infinite alternate;
        }

        .bg-glow-bubble--soft {
            width: 220px;
            height: 220px;
            background: radial-gradient(circle, rgba(251, 207, 232, 0.9) 0, transparent 72%);
            bottom: -40px;
            left: -40px;
            animation: glowFloat2 16s ease-in-out infinite alternate;
        }

        .bg-glow-bubble--tiny {
            width: 120px;
            height: 120px;
            background: radial-gradient(circle, rgba(248, 250, 252, 0.85) 0, transparent 70%);
            top: 40%;
            left: 50%;
            transform: translateX(-50%);
            animation: glowPulse 18s ease-in-out infinite alternate;
        }

        /* =====================================================================
           3. KHUNG CHÍNH AUTH
        ===================================================================== */
        .auth-wrapper {
            min-height: 100vh;
            padding: 32px 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            z-index: 1;
        }

        .auth-inner {
            width: 100%;
            max-width: 480px;
        }

        /* =====================================================================
           4. THẺ ĐĂNG NHẬP
        ===================================================================== */
        .login-card {
            position: relative;
            width: 100%;
            border-radius: var(--hs-radius-xl);
            border: 1px solid var(--hs-card-border);
            background: var(--hs-card-bg);
            box-shadow: var(--hs-shadow-soft), var(--hs-shadow-subtle);
            backdrop-filter: blur(20px);
            padding: 28px 22px;
            overflow: hidden;
            transform-origin: center;
            animation: cardEnter 420ms cubic-bezier(0.23, 0.85, 0.35, 1.1) 60ms both;
        }

        .login-card::before {
            content: "";
            position: absolute;
            inset: 0;
            background:
                radial-gradient(circle at 0% 0%, rgba(255, 255, 255, 0.35) 0, transparent 52%),
                radial-gradient(circle at 100% 100%, rgba(244, 114, 182, 0.22) 0, transparent 58%);
            opacity: 0.9;
            pointer-events: none;
        }

        .login-card-shell {
            position: relative;
            z-index: 1;
        }

        /* =====================================================================
           5. HEADER ĐĂNG NHẬP
        ===================================================================== */
        .login-header {
            text-align: center;
            margin-bottom: 1.5rem;
        }

        .login-title {
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: 0.03em;
            text-transform: uppercase;
            margin-bottom: 0.4rem;
            color: var(--hs-text-main);
        }

        .login-subtitle {
            font-size: 0.92rem;
            color: var(--hs-text-muted);
        }

        /* =====================================================================
           6. THÔNG BÁO LỖI
        ===================================================================== */
        .login-alert {
            margin-bottom: 1rem;
            border-radius: 999px;
            padding: 7px 12px;
            font-size: 0.86rem;
            background: rgba(254, 226, 226, 0.85);
            border: 1px solid rgba(248, 113, 113, 0.7);
            color: #b91c1c;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            animation: alertFadeIn 280ms ease-out both;
        }

        .login-alert i {
            font-size: 0.9rem;
        }

        /* =====================================================================
           7. FORM
        ===================================================================== */
        .form-section {
            margin-bottom: 0.5rem;
        }

        .form-label {
            font-size: 0.85rem;
            font-weight: 600;
            color: #4b5563;
            margin-bottom: 0.35rem;
        }

        .form-control {
            border-radius: var(--hs-radius-lg);
            border: 1px solid var(--hs-input-border);
            background-color: var(--hs-input-bg);
            padding: 0.55rem 0.85rem;
            font-size: 0.92rem;
            transition:
                border-color var(--hs-transition-normal),
                box-shadow var(--hs-transition-normal),
                background-color var(--hs-transition-fast),
                transform var(--hs-transition-fast);
        }

        .form-control:focus {
            outline: none;
            border-color: var(--hs-input-border-focus);
            box-shadow:
                0 0 0 1px rgba(236, 72, 153, 0.3),
                0 10px 35px rgba(236, 72, 153, 0.28);
            background-color: #ffffff;
            transform: translateY(-1px);
        }

        .form-control::placeholder {
            color: rgba(148, 163, 184, 0.9);
            font-size: 0.88rem;
        }

        .input-group {
            border-radius: var(--hs-radius-lg);
            overflow: hidden;
            background-color: var(--hs-input-bg);
        }

        .input-group .form-control {
            border-right: 0;
            border-radius: var(--hs-radius-lg) 0 0 var(--hs-radius-lg);
        }

        .input-group .btn-toggle-pwd {
            border-radius: 0 var(--hs-radius-lg) var(--hs-radius-lg) 0;
            border: 1px solid var(--hs-input-border);
            border-left: 0;
            background: linear-gradient(135deg, rgba(253, 242, 248, 0.9), rgba(251, 207, 232, 0.9));
            color: #9f1239;
            padding-inline: 0.9rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition:
                background-color var(--hs-transition-fast),
                color var(--hs-transition-fast);
        }

        .input-group .btn-toggle-pwd:hover {
            background: linear-gradient(135deg, rgba(251, 207, 232, 1), rgba(249, 168, 212, 1));
            color: #9f1239;
        }

        .input-group .btn-toggle-pwd i {
            font-size: 0.9rem;
        }

        .invalid-feedback {
            font-size: 0.78rem;
            margin-top: 0.2rem;
        }

        /* =====================================================================
           8. NHỚ MẬT KHẨU + QUÊN MẬT KHẨU + ĐĂNG KÝ
        ===================================================================== */
        .login-meta-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
            margin-bottom: 1.1rem;
        }

        .form-check-input {
            width: 15px;
            height: 15px;
            margin-top: 1px;
            border-radius: 5px;
            border-color: rgba(148, 163, 184, 0.8);
            cursor: pointer;
        }

        .form-check-input:checked {
            background-color: var(--hs-primary);
            border-color: var(--hs-primary);
            box-shadow: 0 0 0 2px rgba(236, 72, 153, 0.25);
        }

        .form-check-label {
            font-size: 0.85rem;
            color: #4b5563;
            cursor: pointer;
        }

        .meta-links {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            text-align: right;
            gap: 2px;
        }

        .link-ghost {
            font-size: 0.85rem;
            text-decoration: none;
            color: var(--hs-primary-deep);
            position: relative;
            padding-bottom: 1px;
        }

        .link-ghost::after {
            content: "";
            position: absolute;
            left: 0;
            bottom: 0;
            height: 1px;
            width: 0;
            background: linear-gradient(to right, #f472b6, #ec4899);
            transition: width var(--hs-transition-normal);
        }

        .link-ghost:hover::after {
            width: 100%;
        }

        /* =====================================================================
           9. NÚT ĐĂNG NHẬP
        ===================================================================== */
        .btn-login-main {
            border-radius: var(--hs-radius-pill);
            border: none;
            background:
                radial-gradient(circle at 0% 0%, #f9a8d4 0, transparent 60%),
                linear-gradient(135deg, #ec4899, #db2777);
            color: #ffffff;
            padding: 0.65rem 1rem;
            font-size: 0.98rem;
            font-weight: 600;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            box-shadow: 0 16px 40px rgba(219, 39, 119, 0.45);
            transform: translateY(0);
            transition:
                transform var(--hs-transition-normal),
                box-shadow var(--hs-transition-normal),
                filter var(--hs-transition-fast);
        }

        .btn-login-main i {
            font-size: 0.95rem;
        }

        .btn-login-main:hover {
            transform: translateY(-2px);
            box-shadow: 0 20px 60px rgba(219, 39, 119, 0.65);
            filter: brightness(1.04);
        }

        .btn-login-main:active {
            transform: translateY(0px) scale(0.98);
            box-shadow: 0 10px 30px rgba(190, 24, 93, 0.55);
        }

        /* =====================================================================
           10. NÚT XEM NHƯ KHÁCH
        ===================================================================== */
        .btn-guest {
            border-radius: var(--hs-radius-pill);
            border-width: 1px;
            border-style: solid;
            border-color: rgba(244, 114, 182, 0.6);
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(255, 241, 246, 0.98));
            padding: 0.52rem 1rem;
            font-size: 0.9rem;
            font-weight: 500;
            color: #9f1239;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
            transition:
                background-color var(--hs-transition-fast),
                border-color var(--hs-transition-fast),
                color var(--hs-transition-fast),
                transform var(--hs-transition-fast);
        }

        .btn-guest i {
            font-size: 0.9rem;
        }

        .btn-guest:hover {
            background: linear-gradient(135deg, rgba(255, 228, 239, 1), rgba(254, 242, 255, 1));
            border-color: rgba(236, 72, 153, 0.85);
            color: #9f1239;
            transform: translateY(-1px);
        }

        .btn-guest:active {
            transform: translateY(0);
        }

        /* =====================================================================
           11. FOOTER
        ===================================================================== */
        .login-footer {
            margin-top: 1.1rem;
            padding-top: 0.6rem;
            border-top: 1px solid rgba(248, 187, 208, 0.7);
        }

        .login-footer-text {
            font-size: 0.78rem;
            color: var(--hs-text-muted);
            text-align: center;
        }

        /* =====================================================================
           12. RESPONSIVE
        ===================================================================== */
        @@media (min-width: 576px) {
            .login-card {
                padding: 30px 26px;
            }
        }

        @@media (min-width: 768px) {
            .auth-wrapper {
                padding: 40px 16px;
            }

            .login-card {
                padding: 32px 32px 30px 32px;
            }

            .login-title {
                font-size: 1.6rem;
            }
        }

        @@media (max-width: 575.98px) {
            .auth-wrapper {
                padding-top: 22px;
                padding-bottom: 22px;
            }

            .login-card {
                border-radius: 20px;
                padding: 24px 18px;
            }

            .login-meta-row {
                flex-direction: column;
                align-items: flex-start;
            }

            .meta-links {
                align-items: flex-start;
                text-align: left;
            }

            .btn-login-main {
                font-size: 0.95rem;
            }
        }

        /* =====================================================================
           13. ANIMATIONS
        ===================================================================== */
        @@keyframes cardEnter {
            0% {
                opacity: 0;
                transform: translate3d(0, 14px, 0) scale(0.98);
            }
            60% {
                opacity: 1;
                transform: translate3d(0, -3px, 0) scale(1.01);
            }
            100% {
                opacity: 1;
                transform: translate3d(0, 0, 0) scale(1);
            }
        }

        @@keyframes glowFloat1 {
            0% {
                transform: translate3d(0, 0, 0);
                opacity: 0.85;
            }
            100% {
                transform: translate3d(-14px, 12px, 0);
                opacity: 0.6;
            }
        }

        @@keyframes glowFloat2 {
            0% {
                transform: translate3d(0, 0, 0);
                opacity: 0.7;
            }
            100% {
                transform: translate3d(18px, -18px, 0);
                opacity: 0.45;
            }
        }

        @@keyframes glowPulse {
            0% {
                transform: translate3d(-50%, 0, 0) scale(1);
                opacity: 0.75;
            }
            100% {
                transform: translate3d(-46%, 4px, 0) scale(1.08);
                opacity: 0.4;
            }
        }

        @@keyframes alertFadeIn {
            from {
                opacity: 0;
                transform: translateY(4px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>

    <!-- Glow background elements -->
    <div class="bg-glow-bubble bg-glow-bubble--pink"></div>
    <div class="bg-glow-bubble bg-glow-bubble--soft"></div>
    <div class="bg-glow-bubble bg-glow-bubble--tiny"></div>

    <div class="auth-wrapper">
        <div class="auth-inner">
            <div class="login-card">
                <div class="login-card-shell">

                    <!-- HEADER -->
                    <div class="login-header">
                        <h1 class="login-title">Đăng nhập</h1>
                        <p class="login-subtitle">
                            Nhập thông tin tài khoản để tiếp tục.
                        </p>
                    </div>

                    <!-- THÔNG BÁO LỖI -->
                    @if (ViewBag.Error != null)
                    {
                        <div class="login-alert">
                            <i class="fa-regular fa-circle-xmark"></i>
                            <span>@ViewBag.Error</span>
                        </div>
                    }

                    <!-- FORM -->
                    @using (Html.BeginForm("DangNhap", "Home", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate", id = "loginForm" }))
                    {
                        @Html.AntiForgeryToken()

                        <div class="form-section">
                            <!-- Email / Phone -->
                            <div class="mb-3">
                                <label class="form-label" for="account">Email hoặc số điện thoại</label>
                                <input type="text"
                                       id="account"
                                       name="account"
                                       class="form-control"
                                       autocomplete="username"
                                       placeholder="email@domain.com hoặc 0xxxxxxxxx"
                                       required />
                                <div class="invalid-feedback">
                                    Vui lòng nhập email hoặc số điện thoại.
                                </div>
                            </div>

                            <!-- Mật khẩu -->
                            <div class="mb-2">
                                <label class="form-label" for="password">Mật khẩu</label>
                                <div class="input-group">
                                    <input type="password"
                                           id="password"
                                           name="password"
                                           class="form-control"
                                           minlength="3"
                                           autocomplete="current-password"
                                           placeholder="Nhập mật khẩu của bạn"
                                           required />
                                    <button type="button"
                                            class="btn btn-toggle-pwd"
                                            id="togglePwd"
                                            aria-label="Hiện / ẩn mật khẩu">
                                        <i class="fa-regular fa-eye"></i>
                                    </button>
                                </div>
                                <div class="invalid-feedback">
                                    Vui lòng nhập mật khẩu.
                                </div>
                            </div>
                        </div>

                        <!-- Nhớ mật khẩu + QUÊN MẬT KHẨU + ĐĂNG KÝ -->
                        <div class="login-meta-row">
                            <div class="form-check">
                                <input type="checkbox"
                                       class="form-check-input"
                                       id="rememberMe"
                                       name="rememberMe" />
                                <label for="rememberMe" class="form-check-label">
                                    Ghi nhớ đăng nhập
                                </label>
                            </div>

                            <div class="meta-links">
                                <a href="@Url.Action("DangKy", "Home")" class="link-ghost">
                                    Đăng ký tài khoản
                                </a>
                            </div>
                        </div>

                        <!-- Nút đăng nhập -->
                        <div class="d-grid mb-2">
                            <button type="submit" class="btn btn-login-main">
                                <i class="fa-solid fa-right-to-bracket"></i>
                                <span>Đăng nhập</span>
                            </button>
                        </div>

                        <!-- Nút xem như khách -->
                        <div class="d-grid mb-1">
                            <a href="@Url.Action("About", "Home")" class="btn btn-guest">
                                <i class="fa-solid fa-eye"></i>
                                <span>Xem nhanh như khách</span>
                            </a>
                        </div>
                    }

                    <!-- Footer nhỏ -->
                    <div class="login-footer">
                        <p class="login-footer-text">
                            Thông tin của bạn được bảo vệ – chỉ dùng để hỗ trợ trải nghiệm mua sắm.
                        </p>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // 1. Toggle hiển / ẩn mật khẩu
        (function () {
            var toggleBtn = document.getElementById("togglePwd");
            var pwdInput = document.getElementById("password");

            if (toggleBtn && pwdInput) {
                toggleBtn.addEventListener("click", function () {
                    var isPwd = pwdInput.getAttribute("type") === "password";
                    pwdInput.setAttribute("type", isPwd ? "text" : "password");

                    var icon = this.querySelector("i");
                    if (icon) {
                        if (isPwd) {
                            icon.classList.remove("fa-eye");
                            icon.classList.add("fa-eye-slash");
                        } else {
                            icon.classList.remove("fa-eye-slash");
                            icon.classList.add("fa-eye");
                        }
                    }
                });
            }
        })();

        // 2. Validation nhẹ kiểu Bootstrap
        (function () {
            var form = document.getElementById("loginForm");
            if (!form) return;

            form.addEventListener("submit", function (event) {
                if (!form.checkValidity()) {
                    event.preventDefault();
                    event.stopPropagation();
                }
                form.classList.add("was-validated");
            });
        })();

        // 3. Focus auto vào ô account khi vào trang
        (function () {
            var acc = document.getElementById("account");
            if (acc) {
                setTimeout(function () {
                    try { acc.focus(); } catch (e) { }
                }, 260);
            }
        })();
    </script>

</body>
</html>

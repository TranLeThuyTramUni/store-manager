        }

        .hs-brand-logo-text {
            flex: 1;
        }

            .hs-brand-logo-text strong {
                font-size: .92rem;
                color: #111827;
            }

            .hs-brand-logo-text span {
                display: block;
                font-size: .78rem;
                color: #6b7280;
            }

        .hs-brand-logo-pill {
            font-size: .75rem;
            border-radius: 999px;
            padding: .15rem .6rem;
            background: #eff6ff;
            color: #1d4ed8;
            white-space: nowrap;
        }

        /* TRENDING SEARCH / KEYWORDS */
        .hs-trending {
            border-radius: 1.8rem;
            background: linear-gradient(135deg, #ffffff 0%, #f3f4f6 100%);
            padding: 1.25rem 1.3rem;
            box-shadow: 0 10px 25px rgba(0,0,0,0.06);
            border: 1px solid rgba(0,0,0,0.04);
        }

        /* Header */
        .hs-trending-header {
            margin-bottom: 1rem;
        }

        .hs-trending-title {
            display: flex;
            align-items: center;
            gap: .5rem;
            font-size: 1rem;
            font-weight: 700;
            color: #0f172a;
        }

            .hs-trending-title i {
                color: #fb923c;
                font-size: 1rem;
            }

        .hs-trending-sub {
            margin-top: .2rem;
            font-size: .82rem;
            color: #6b7280;
        }

        /* Tags area */
        .hs-trending-tags {
            margin-top: .4rem;
            display: flex;
            flex-wrap: wrap;
            gap: .5rem .6rem;
        }

        /* ⛔ Không click được */
        .hs-trending-tag {
            pointer-events: none;
            user-select: none;
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            padding: .32rem .85rem;
            border-radius: 999px;
            font-size: .82rem;
            background: #ffffff;
            border: 1px solid #e5e7eb;
            color: #374151;
            font-weight: 500;
            box-shadow: 0 2px 6px rgba(0,0,0,0.04);
        }

            /* Icon */
            .hs-trending-tag i {
                font-size: .8rem;
                color: #9ca3af;
            }

            /* HOT TAG (Premium look) */
            .hs-trending-tag.hot {
                background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
                border-color: #fdba74;
                color: #9a3412;
            }

                .hs-trending-tag.hot i {
                    color: #fb923c;
                }

        /* BLOG / MAGAZINE */
        .hs-mag-card {
            border-radius: 1.6rem;
            overflow: hidden;
            background: #ffffff;
            border: 1px solid #e5e7eb;
            display: flex;
            flex-direction: column;
            height: 100%;
            box-shadow: 0 16px 40px rgba(15, 23, 42, 0.06);
        }

        .hs-mag-media {
            position: relative;
            overflow: hidden;
        }

            .hs-mag-media img {
                width: 100%;
                display: block;
                object-fit: cover;
                max-height: 220px;
                transition: transform .35s ease;
            }

        .hs-mag-card:hover .hs-mag-media img {
            transform: scale(1.05);
        }

        .hs-mag-pill {
            position: absolute;
            left: .9rem;
            top: .8rem;
            border-radius: 999px;
            padding: .18rem .65rem;
            background: rgba(15, 23, 42, 0.85);
            font-size: .75rem;
            color: #e5e7eb;
        }

        .hs-mag-body {
            padding: .9rem .95rem 1rem;
            display: flex;
            flex-direction: column;
            gap: .4rem;
        }

        .hs-mag-meta {
            display: flex;
            align-items: center;
            gap: .5rem;
            font-size: .78rem;
            color: #9ca3af;
        }

            .hs-mag-meta span.dot::before {
                content: "•";
                margin-right: .35rem;
            }

        .hs-mag-title a {
            font-weight: 600;
            font-size: .98rem;
            color: #111827;
            text-decoration: none;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

            .hs-mag-title a:hover {
                color: #1d4ed8;
            }

        .hs-mag-excerpt {
            font-size: .86rem;
            color: #6b7280;
        }

        .hs-mag-footer {
            margin-top: .45rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: .8rem;
        }

            .hs-mag-footer a {
                color: #1d4ed8;
                text-decoration: none;
                display: inline-flex;
                align-items: center;
                gap: .25rem;
            }

        /* VOUCHER / PROMO BANNER */
        .hs-promo-grid {
            /*display: grid;
            grid-template-columns: repeat(12, minmax(0, 1fr));
            gap: 1rem;*/
        }

        @@media (max-width: 767.98px) {
            .hs-promo-grid {
                grid-template-columns: repeat(1, minmax(0, 1fr));
            }
        }

        .hs-promo-card {
            border-radius: 1.6rem;
            padding: 1rem;
            color: #f9fafb;
            position: relative;
            overflow: hidden;
            min-height: 165px;
        }

            .hs-promo-card::before {
                content: "";
                position: absolute;
                inset: 0;
                background: radial-gradient(circle at 0 0, rgba(255, 255, 255, 0.35) 0, transparent 60%);
                opacity: .85;
            }

        .hs-promo-inner {
            position: relative;
            z-index: 1;
        }

        .hs-promo-title {
            font-size: 1.1rem;
            font-weight: 700;
        }

        .hs-promo-sub {
            font-size: .9rem;
        }

        .hs-promo-tag {
            display: inline-flex;
            align-items: center;
            gap: .25rem;
            border-radius: 999px;
            padding: .2rem .65rem;
            border: 1px dashed rgba(249, 250, 251, 0.6);
            font-size: .78rem;
            margin-bottom: .3rem;
        }

        .hs-promo-code {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            margin-top: .6rem;
            font-size: .86rem;
        }

            .hs-promo-code span.code {
                border-radius: .7rem;
                padding: .2rem .55rem;
                background: rgba(15, 23, 42, 0.93);
                letter-spacing: .18em;
                text-transform: uppercase;
                font-weight: 700;
            }

        .hs-promo-badge {
            position: absolute;
            right: 1rem;
            bottom: .9rem;
            border-radius: 999px;
            padding: .2rem .55rem;
            background: rgba(15, 23, 42, 0.18);
            font-size: .78rem;
        }

        .hs-promo-cta {
            margin-top: .65rem;
            font-size: .78rem;
        }

        /* MEMBERSHIP / LOYALTY */
        .hs-membership {

            border-radius: 2rem;
            background: radial-gradient(circle at 0 0, #312e81, #0f172a);
            color: #e5e7eb;
            padding: 1.6rem 1.4rem;
            position: relative;
            overflow: hidden;
        }

        @@media (min-width: 992px) {
            .hs-membership {
                padding: 2rem 1.8rem;
            }
        }

        .hs-membership::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 100% 0, rgba(244, 114, 182, 0.6) 0, transparent 55%), radial-gradient(circle at 0% 100%, rgba(96, 165, 250, 0.55) 0, transparent 55%);
            opacity: .7;
        }

        .hs-membership-inner {
            position: relative;
            z-index: 1;
        }

        .hs-membership-badge {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            border-radius: 999px;
            padding: .2rem .65rem;
            border: 1px solid rgba(249, 250, 251, 0.45);
            font-size: .78rem;
            margin-bottom: .45rem;
        }

        .hs-membership-title {
            font-size: 1.45rem;
            font-weight: 800;
            letter-spacing: -0.04em;
        }

        .hs-membership-sub {
            font-size: .9rem;
            color: #e5e7eb;
        }

        .hs-membership-perks {
            margin-top: .85rem;
            display: flex;
            flex-wrap: wrap;
            gap: .75rem 1.2rem;
        }

        .hs-membership-perk {
            display: flex;
            align-items: center;
            gap: .4rem;
            font-size: .86rem;
        }

            .hs-membership-perk i {
                color: #facc15;
            }

        .hs-membership-card {
            margin-top: 1rem;
            border-radius: 1.5rem;
            background: linear-gradient(135deg, rgba(15, 23, 42, 0.85), rgba(30, 64, 175, 0.92));
            padding: .8rem .9rem;
            max-width: 270px;
        }

        .hs-membership-card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: .3rem;
            font-size: .78rem;
        }

        .hs-membership-card-no {
            letter-spacing: .22em;
            text-transform: uppercase;
            font-size: .75rem;
        }

        .hs-membership-card-name {
            margin-top: .35rem;
            font-size: .9rem;
            font-weight: 600;
        }

        .hs-membership-card-tier {
            font-size: .75rem;
            color: #e5e7eb;
        }

        /* NEWSLETTER / SUBSCRIBE */
        /* ===================== NEWSLETTER WRAPPER (CHỮ TỐI) ===================== */
        .hs-newsletter {
            border-radius: 1.8rem;
            background: linear-gradient(135deg, #fdfdfd, #e5e7eb); /* nền sáng hơn để chữ tối cực rõ */
            color: #1e293b; /* text tối */
            padding: 1.6rem 1.4rem;
            position: relative;
            overflow: hidden;
        }

            .hs-newsletter::before {
                content: "";
                position: absolute;
                inset: 0;
                background: radial-gradient(circle at 0% 100%, rgba(251, 113, 133, 0.25) 0, transparent 65%);
                opacity: .6;
            }

        /* ===================== INNER ===================== */
        .hs-newsletter-inner {
            position: relative;
            z-index: 1;
        }

        /* ===================== TITLE ===================== */
        /* Chữ tối + đậm để nổi thật mạnh */
        .hs-newsletter-title {
            font-size: 1.3rem;
            font-weight: 900;
            color: #1f2937; /* xám than đậm */
        }

        /* ===================== SUB TEXT ===================== */
        .hs-newsletter-sub {
            font-size: .92rem;
            color: #374151; /* xám đậm rõ ràng */
            opacity: 1;
        }

        /* ===================== FORM ===================== */
        .hs-newsletter-form {
            margin-top: .85rem;
            display: flex;
            flex-wrap: wrap;
            gap: .5rem;
        }

            .hs-newsletter-form .form-control {
                border-radius: 999px;
                border: 1px solid #cbd5e1;
                background: #ffffff;
                font-size: .9rem;
                color: #111827; /* chữ đen */
                padding: .45rem 1rem;
            }

                .hs-newsletter-form .form-control::placeholder {
                    color: #6b7280; /* xám tối nhẹ */
                }

        /* ===================== BUTTON ===================== */
        .hs-newsletter-btn {
            border-radius: 999px;
            border: none;
            background: #f97316; /* cam đậm */
            color: #1f1f1f; /* chữ tối */
            font-size: .9rem;
            font-weight: 700;
            padding: .45rem 1.3rem;
            box-shadow: 0 4px 14px rgba(249, 115, 22, 0.35);
            transition: 0.2s ease;
        }

            .hs-newsletter-btn:hover {
                background: #ea580c;
                box-shadow: 0 6px 18px rgba(234, 88, 12, 0.45);
            }

        /* ===================== NOTE ===================== */
        .hs-newsletter-note {
            margin-top: .45rem;
            font-size: .78rem;
            color: #475569; /* xám tối */
        }


        /* ===================== STORE / OFFLINE CTA ===================== */

.hs-store-card {
    position: relative;
    border-radius: 1.6rem;
    padding: 1.1rem 1.15rem 1.25rem;
    background:
        radial-gradient(circle at 0% 0%, rgba(252, 231, 243, 0.9) 0, transparent 55%),
        radial-gradient(circle at 100% 100%, rgba(219, 234, 254, 0.9) 0, transparent 55%),
        #ffffff;
    border: 1px solid rgba(148, 163, 184, 0.45);
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    overflow: hidden;
}

/* dải highlight nhỏ bên trên cho sang */
.hs-store-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(244, 114, 182, 0.28), rgba(56, 189, 248, 0.22));
    opacity: 0.35;
    pointer-events: none;
}

.hs-store-card > * {
    position: relative;
    z-index: 1;
}

.hs-store-title {
    font-size: 1rem;
    font-weight: 800;
    color: #111827;
    display: flex;
    align-items: center;
}

.hs-store-title i {
    font-size: 1.1rem;
}

/* mô tả chính – chữ tối, dễ đọc */
.hs-store-meta {
    font-size: 0.86rem;
    color: #4b5563;
}

/* stats “fake hệ thống cửa hàng” */
.hs-store-stats {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: #6b7280;
}

.hs-store-stat strong {
    font-weight: 800;
    color: #111827;
}

.hs-store-dot {
    width: 4px;
    height: 4px;
    border-radius: 999px;
    background: #9ca3af;
}

/* chips thành phố */
.hs-store-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
}

.hs-store-chip {
    border-radius: 999px;
    padding: 0.2rem 0.7rem;
    font-size: 0.78rem;
    background: rgba(243, 244, 246, 0.9);
    color: #374151;
    border: 1px solid rgba(209, 213, 219, 0.9);
    transition: background 0.18s ease, color 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
}


/* responsive nhẹ */
@@media (max-width: 576px) {
    .hs-store-card {
        padding: 1rem 1rem 1.1rem;
    }

    .hs-store-meta {
        font-size: 0.84rem;
    }
}


        /* SMALL UTILITIES */
        .text-gradient-primary {
            background: linear-gradient(120deg, #1c4b82, #0f172a);
            -webkit-background-clip: text;
            color: transparent;
        }

        .text-gradient-accent {
            background: linear-gradient(120deg, #fb7185, #f97316);
            -webkit-background-clip: text;
            color: transparent;
        }

        .border-dashed {
            border-style: dashed !important;
        }

        .opacity-80 {
            opacity: .8;
        }

        .opacity-60 {
            opacity: .6;
        }

        .fs-13 {
            font-size: .82rem;
        }

        .fs-14 {
            font-size: .88rem;
        }

        .rounded-3xl {
            border-radius: 1.8rem;
        }

        .rounded-4xl {
            border-radius: 2.4rem;
        }
        /* ================= BEST SELLER – 3 STYLE KHÁC NHAU ================= */

        /* ANIMATION CHUNG */
        @@keyframes hsFloatIn {
            from {
                opacity: 0;
                transform: translateY(12px) scale(.96);
            }

            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        /* --- 1. SKINCARE: SLIDER NGANG, CARD HỒNG PASTEL --- */

        .hs-skin-row {
            display: flex;
            gap: .7rem;
            overflow-x: auto;
            padding-bottom: .3rem;
            scroll-snap-type: x mandatory;
            scrollbar-width: thin;
        }

            .hs-skin-row::-webkit-scrollbar {
                height: 5px;
            }

            .hs-skin-row::-webkit-scrollbar-thumb {
                background: rgba(236, 72, 153, .45);
                border-radius: 999px;
            }

        /* CARD */
        .hs-skin-card {
            scroll-snap-align: start;
            min-width: 240px;
            max-width: 260px;
            border-radius: 1.6rem;
            background: radial-gradient(circle at 0 0, #ffe4ec, #fce7f3);
            border: 1px solid rgba(236, 72, 153, .25);
            padding: .6rem;
            display: flex;
            flex-direction: column;
            height: 100%;
            box-shadow: 0 16px 45px rgba(236, 72, 153, .15);
            animation: hsFloatIn .6s ease both;
        }

        .hs-skin-media {
            border-radius: 1.3rem;
            overflow: hidden;
            background: #fff5f7;
            padding: .4rem;
        }

            .hs-skin-media img {
                width: 100%;
                object-fit: contain;
                transition: transform .35s ease;
            }

        .hs-skin-card:hover .hs-skin-media img {
            transform: translateY(-4px) scale(1.06);
        }

        /* Pill tag */


        .hs-skin-pill {
            border-radius: 999px;
            padding: .15rem .55rem;
            font-size: .75rem;
            background: rgba(244, 114, 182, .15);
            color: #be185d;
            display: inline-flex;
            align-items: center;
            gap: .25rem;
        }

            .hs-skin-pill i {
                font-size: .78rem;
            }
        /* --- 2. MAKEUP: STYLE HỒNG LUXURY --- */

        .hs-makeup-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: .75rem;
        }

        @@media (min-width: 768px) {
            .hs-makeup-grid {
                grid-template-columns: repeat(4, 1fr);
            }
        }

        .hs-makeup-card {
            border-radius: 1.2rem;
            background: #ffffff;
            border: 1px solid #fbcfe8;
            padding: .6rem .65rem .7rem;
            box-shadow: 0 18px 40px rgba(236, 72, 153, .22);
            text-align: center;
            position: relative;
            overflow: hidden;
            animation: hsFloatIn .6s ease both;
        }

            .hs-makeup-card::before {
                content: "";
                position: absolute;
                inset: 0;
                background: radial-gradient(circle at 0 0, rgba(255, 228, 230, .9), transparent 60%);
                opacity: .95;
                pointer-events: none;
            }

        /* Bọc avatar */
        .hs-makeup-avatar-wrap {
            width: 92px;
            height: 92px;
            border-radius: 999px;
            padding: .2rem;
            background: linear-gradient(135deg, #f472b6, #fb7185);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto .35rem;
            text-align: center;

        }

        .hs-makeup-avatar {
            width: 100%;
            height: 100%;
            border-radius: 999px;
            overflow: hidden;
            background: #fff1f2;
        }

            .hs-makeup-avatar img {
                width: 100%;
                height: 100%;
                object-fit: contain;
                transition: transform .35s ease;
            }

        .hs-makeup-card:hover .hs-makeup-avatar img {
            transform: scale(1.08) rotate(-3deg);
        }

        /* Badge */
        .hs-makeup-badge {
            position: absolute;
            top: .5rem;
            right: .55rem;
            border-radius: 999px;
            padding: .12rem .5rem;
            background: #be185d;
            color: #ffe4e6;
            font-size: .72rem;
            display: inline-flex;
            align-items: center;
            gap: .22rem;
        }

        /* Name */
        .hs-makeup-name {
            font-size: .9rem;
            font-weight: 600;
            color: #9d174d;
            max-height: 2.8em;
            overflow: hidden;
        }

        /* Price */
        .hs-makeup-price {
            margin-top: .15rem;
            font-size: .95rem;
            font-weight: 700;
            color: #be185d;
        }

        .hs-makeup-old {
            font-size: .78rem;
            text-decoration: line-through;
            color: #9ca3af;
        }
        /* ==== POSTER BRAND CARD ==== */
        .hs-brand-poster-card {
            display: block;
            position: relative;
            border-radius: 1.5rem;
            overflow: hidden;
            text-decoration: none;
            color: #fff;
            height: 240px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.20);
            transition: transform .35s ease, box-shadow .35s ease;
        }

            .hs-brand-poster-card:hover {
                transform: translateY(-6px);
                box-shadow: 0 20px 45px rgba(0,0,0,0.28);
            }

        /* Background ảnh */
        .hs-brand-poster-img {
            position: absolute;
            inset: 0;
            background-size: cover;
            background-position: center;
            filter: brightness(0.78);
            transition: filter .35s ease, transform .35s ease;
        }

        .hs-brand-poster-card:hover .hs-brand-poster-img {
            filter: brightness(0.95);
            transform: scale(1.08);
        }

        /* Overlay gradient */
        .hs-brand-poster-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, rgba(0,0,0,0.05), rgba(0,0,0,0.55));
            z-index: 1;
        }

        /* Text */
        .hs-brand-poster-content {
            position: absolute;
            z-index: 2;
            bottom: 1.2rem;
            left: 1.2rem;
            right: 1.2rem;
        }

            .hs-brand-poster-content .title {
                font-size: 1.35rem;
                font-weight: 700;
                letter-spacing: 0.5px;
                margin-bottom: 0.35rem;
            }

            .hs-brand-poster-content .desc {
                font-size: 0.92rem;
                opacity: 0.9;
                line-height: 1.35;
            }
        .brand-card {
            position: relative;
            display: block;
            height: 260px;
            border-radius: 1.5rem;
            overflow: hidden;
            color: #fff;
            text-decoration: none;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        }

        /* Ảnh bắt buộc fill toàn card */
        .brand-img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            z-index: 0;
            transition: transform .3s ease;
        }

        .brand-card:hover .brand-img {
            transform: scale(1.08);
        }

        /* Gradient nhẹ dưới */
        .brand-gradient {
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, transparent 20%, rgba(0,0,0,0.55));
            z-index: 1;
        }

        /* Text nổi lên trên */
        .brand-text {
            position: absolute;
            z-index: 2;
            bottom: 1.3rem;
            left: 1.3rem;
            right: 1.3rem;
        }

            .brand-text h3 {
                font-weight: 700;
                margin-bottom: 4px;
            }

            .brand-text p {
                margin: 0;
                opacity: .95;
            }
        /* ===================== FLASH SALE CONTENT ===================== */

        /* ===================== FLASH SALE TEXT – HIGH CONTRAST ===================== */

        /* Label FLASH SALE – cam neon nổi rõ */
        .hs-flash-label {
            color: #ffb347; /* cam đậm */
        }

            .hs-flash-label i {
                color: #ff8f00; /* cam neon */
            }

        /* Tiêu đề – gradient tím → hồng đậm → đỏ neon */
        .hs-flash-title {
            background: linear-gradient(90deg, #b833ff, #ff2f85, #ff1e43);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Sub text – tím pastel đậm */
        .hs-flash-sub {
            color: #f3c8ff; /* tím nhạt nhưng đậm hơn vàng */
        }

        /* COUNTDOWN text */
        .hs-flash-countdown > span:first-child {
            color: #ffe1f4; /* hồng kem */
        }

        /* Countdown số – chữ trắng đậm để nổi */
        .hs-flash-countdown .badge {
            color: #ffffff !important;
            font-weight: 800;
        }

        /* Link “Xem tất cả khuyến mãi” – hồng neon đậm */
        .hs-flash-link-all {
            color: #ff3f73 !important;
            font-weight: 700;
        }

            .hs-flash-link-all:hover {
                color: #ff6fa1 !important;
            }

        /* Text mô tả phải – tím hồng rõ hơn */
        .fs-13.opacity-80 {
            color: #f8cfff !important;
        }

        /* Icon arrow – hồng neon */
        .hs-flash-link-all i {
            color: #ff3f73 !important;
        }
        /* ===================== FLASH SALE COUNTDOWN RED ===================== */

        /* Chữ "Sale kết thúc sau" */
        .hs-flash-countdown > span:first-child {
            color: #b30024; /* đỏ đậm, rõ, luxury */
            font-weight: 600;
        }

        /* Các khối số đếm (02 : 59 : 44) */
        .hs-flash-countdown .badge {
            background: #ff0033 !important; /* đỏ neon đậm */
            color: #ffffff !important; /* chữ trắng cho tương phản mạnh */
            box-shadow: 0 0 12px rgba(255, 0, 51, 0.6);
            font-weight: 800;
            border: none;
        }

        /* Dấu ":" giữa số — cho đỏ đậm luôn */
        .hs-flash-countdown span:not(.badge):not(:first-child) {
            color: #ff002a;
            font-weight: 900;
        }


    </style>
}


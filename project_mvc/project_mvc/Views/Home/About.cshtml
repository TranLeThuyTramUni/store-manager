@model project_mvc.Models.HomeAboutViewModel

@{
    ViewBag.Title = "Trang chủ - The Face Shop";
    Layout = "~/Views/Shared/View.cshtml";

    // Helper format tiền
    Func<decimal?, string> money = v =>
    {
        var value = v ?? 0;
        return string.Format(
            System.Globalization.CultureInfo.GetCultureInfo("vi-VN"),
            "{0:N0} ₫", value
        );
    };
}

@section Styles {
    <style>


        body {
            font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        .hs-section {
            padding-top: 2.5rem;
            padding-bottom: 2.5rem;
        }

        @@media (min-width: 992px) {
            .hs-section {
                padding-top: 3.5rem;
                padding-bottom: 3.5rem;
            }
        }

        .hs-section-title {
            font-size: 1.1rem;
            letter-spacing: .16em;
            text-transform: uppercase;
            color: var(--hs-accent);
            font-weight: 600;
            margin-bottom: .4rem;
        }

        .hs-section-heading {
            font-size: 1.7rem;
            font-weight: 700;
            color: var(--hs-dark);
            letter-spacing: -0.03em;
        }

        @@media (min-width: 992px) {
            .hs-section-heading {
                font-size: 2rem;
            }
        }

        .hs-section-description {
            color: var(--hs-muted);
            font-size: .97rem;
        }

        /* Top announcement / USP strip */
        .hs-top-strip {
            background: linear-gradient(90deg, #fee2f2, #e0f2ff);
            border-radius: 999px;
            padding: .35rem .9rem;

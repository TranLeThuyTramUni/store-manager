@section Scripts {
    <script>
        // ====== FLASH SALE COUNTDOWN (DEMO) ======
        (function () {
            // Set demo countdown 3 giờ từ lúc load
            var duration = 3 * 60 * 60; // 3h -> seconds
            var endTime = Date.now() + duration * 1000;

            function pad(num) {
                return num < 10 ? "0" + num : "" + num;
            }

            function updateCountdown() {
                var now = Date.now();
                var diff = Math.max(0, Math.floor((endTime - now) / 1000));
                var h = Math.floor(diff / 3600);
                var m = Math.floor((diff % 3600) / 60);
                var s = diff % 60;

                var hEl = document.getElementById("hsFlashHour");
                var mEl = document.getElementById("hsFlashMinute");
                var sEl = document.getElementById("hsFlashSecond");

                if (!hEl || !mEl || !sEl) return;

                hEl.textContent = pad(h);
                mEl.textContent = pad(m);
                sEl.textContent = pad(s);

                if (diff <= 0) {
                    clearInterval(timer);
                }
            }

            updateCountdown();
            var timer = setInterval(updateCountdown, 1000);
        })();

        // ====== SCROLL NAV ACTIVE STATE ======
        (function () {
            var navLinks = document.querySelectorAll(".hs-scroll-nav-pill");

            navLinks.forEach(function (link) {
                link.addEventListener("click", function (e) {
                    // scroll tới id
                    var href = this.getAttribute("href");
                    if (href && href.startsWith("#")) {
                        e.preventDefault();
                        var target = document.querySelector(href);
                        if (target) {
                            window.scrollTo({
                                top: target.getBoundingClientRect().top + window.pageYOffset - 100,
                                behavior: "smooth"
                            });
                        }
                    }

                    // set active
                    navLinks.forEach(function (l) { l.classList.remove("active"); });
                    this.classList.add("active");
                });
            });
        })();

        // ====== FLOATING SUPPORT BUTTON (DEMO) ======
        (function () {
            var btn = document.getElementById("hsSupportBtn");
            var tooltip = document.querySelector(".hs-support-tooltip");

            if (!btn || !tooltip) return;

            btn.addEventListener("mouseenter", function () {
                tooltip.style.opacity = "1";
            });

            btn.addEventListener("mouseleave", function () {
                tooltip.style.opacity = "1";
            });

            btn.addEventListener("click", function () {
                alert("Tư vấn viên The Face Shop sẽ sớm hỗ trợ bạn. (Tích hợp chat / hotline sau này)");
            });
        })();
    </script>
}


    <!-- ================= FLASH SALE ================= -->
    <section id="flash-sale" class="hs-section pt-2">
        <div class="hs-flash-wrapper">
            <div class="hs-flash-inner">
                <div class="hs-flash-heading">
                    <div>
                        <div class="hs-flash-label">
                            <i class="fa-solid fa-bolt"></i>
                            FLASH SALE GIỜ VÀNG
                        </div>
                        <div class="hs-flash-title">
                            Săn deal đậm – chốt đơn liền tay.
                        </div>
                        <div class="hs-flash-countdown mt-1">
                            <span>Sale kết thúc sau</span>
                            <span class="badge" id="hsFlashHour">03</span>:
                            <span class="badge" id="hsFlashMinute">12</span>:
                            <span class="badge" id="hsFlashSecond">45</span>
                        </div>
                    </div>
                 
                </div>

                <div class="row g-2 g-sm-3 g-md-3 g-lg-4">
                    @if (Model.FlashSale != null && Model.FlashSale.Any())
                    {
                        foreach (var sp in Model.FlashSale.Take(8))

                        {
                            var url = Url.Action("Details", "SanPham", new { id = sp.MASP });

                            string spImg = Url.Content("~/images/" + (string.IsNullOrWhiteSpace(sp.HINHANH)
                                ? "no-image.png"
                                : sp.HINHANH));

                            string brandName = sp.THUONGHIEU != null ? sp.THUONGHIEU.TENTH : "Thương hiệu khác";
                            string catName = sp.DANHMUC != null ? sp.DANHMUC.TENDANHMUC : sp.MADM;

                            decimal giaBan = sp.GIABAN;        // vì GIABAN là decimal, không nullable
                            decimal km = sp.KHUYENMAI;     // nếu KHUYENMAI cũng là decimal, không nullable
                            decimal giaGoc = km > 0
                                ? Math.Round(giaBan / (1 - km / 100m), 0)
                                : giaBan;

                            string kmText = km > 0 ? $"-{km:0}% OFF" : "Ưu đãi";
                            <div class="col-6 col-sm-4 col-md-3 col-lg-3">
                                <article class="hs-product-card">
                                    <div class="hs-product-media">
                                        <a href="@url">
                                            <img src="@spImg" alt="@sp.TENSP" />
                                        </a>

                                        @if (km > 0)
                                        {
                                            <div class="hs-product-badge-sale">
                                                <i class="fa-solid fa-fire-flame-curved"></i>
                                                @kmText
                                            </div>
                                        }

                                        <div class="hs-product-badge-tag">
                                            <i class="fa-solid fa-bolt-lightning"></i>
                                            Flash deal
                                        </div>
                                    </div>

                                    <div class="hs-product-body">
                                        <div class="hs-product-brand">
                                            @brandName
                                        </div>
                                        <div class="hs-product-name">
                                            <a href="@url" title="@sp.TENSP">@sp.TENSP</a>
                                        </div>
                                        <div class="hs-product-category">
                                            @catName
                                        </div>

                                        <div class="hs-product-price-wrap">
                                            <div class="hs-product-price-current">
                                                @money(giaBan)
                                            </div>

                                            @if (km > 0 && giaGoc > giaBan)
                                            {
                                                <div class="hs-product-price-old">
                                                    @money(giaGoc)
                                                </div>
                                            }
                                        </div>

                                        <div class="hs-product-rating">
                                            <span>
                                                <i class="fa-solid fa-star"></i>
                                                4.9/5
                                            </span>
                                            <span class="opacity-60">•</span>
                                            <span>+150 đánh giá</span>
                                        </div>

                                        <div class="hs-product-actions">
                                            <a href="@url" class="hs-product-btn-add">
                                                <i class="fa-solid fa-eye"></i>
                                                Xem chi tiết
                                            </a>
                                        </div>
                                    </div>
                                </article>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12">
                            <div class="text-center text-light fs-14 opacity-80 py-3">
                                Hiện chưa có sản phẩm Flash Sale. Vui lòng quay lại sau nhé!
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

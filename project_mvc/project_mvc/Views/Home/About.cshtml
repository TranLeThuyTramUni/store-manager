            color: #4b5563;
            background: #fff;
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            text-decoration: none;
        }

            .hs-scroll-nav-pill i {
                font-size: .85rem;
                color: var(--hs-accent);
            }

            .hs-scroll-nav-pill.active {
                background: #0f172a;
                color: #f9fafb;
                border-color: #0f172a;
            }

        /* FLASH SALE */
        /* ===================== FLASH SALE WRAPPER (HỒNG LUXURY) ===================== */
        /* ===================== FLASH SALE WRAPPER (HỒNG LUXURY) ===================== */
        .hs-flash-wrapper {
            border-radius: 2rem;
            background: linear-gradient(135deg, #ffe4ef 0%, #ff9abb 40%, #ff6f9a 100%);
            color: #fff;
            padding: 1.7rem 1.3rem 1.5rem;
            position: relative;
            overflow: hidden;
            box-shadow: 0 20px 50px rgba(255, 111, 154, 0.22);
        }

            .hs-flash-wrapper::before {
                content: "";
                position: absolute;
                inset: 0;
                background: radial-gradient(circle at 0% 0%, rgba(255, 255, 255, 0.30) 0, transparent 55%), radial-gradient(circle at 100% 100%, rgba(255, 158, 195, 0.38) 0, transparent 55%);
                opacity: .65;
                pointer-events: none;
            }

        .hs-flash-inner {
            position: relative;
            z-index: 1;
        }

        /* ===================== FLASH LABEL – TITLE – SUB ===================== */
        .hs-flash-label {
            display: inline-flex;
            align-items: center;
            gap: .5rem;
            text-transform: uppercase;
            letter-spacing: .18em;
            font-size: .8rem;
            color: #ffe3ef;
        }

            .hs-flash-label i {
                color: #ffebf4;
            }

        .hs-flash-title {
    font-size: 2rem;              /* tăng cỡ chữ lớn hơn */
    font-weight: 900;             /* siêu đậm */
    line-height: 1.25;
    background: linear-gradient(90deg,
                #ff004c,         /* đỏ neon nổi bật */
                #ff3d9a,         /* hồng neon */
                #b300ff);        /* tím đậm tương phản */
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 2px 4px rgba(255,0,80,0.25));
}

/* Responsive cho mobile */
@@media (max-width: 576px) {
    .hs-flash-title {
        font-size: 1.65rem;
    }
}

        .hs-flash-sub {
            font-size: .92rem;
            color: #ffddea;
        }

        /* ===================== COUNTDOWN ===================== */
        .hs-flash-countdown {
            display: inline-flex;
            gap: .3rem;

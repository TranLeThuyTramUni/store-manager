            overflow: hidden;
            box-shadow: 0 14px 32px rgba(76, 29, 149, 0.26), 0 6px 18px rgba(236, 72, 153, 0.16);
        }

        /* ===================== PRODUCT MEDIA ===================== */
        .hs-product-media {
            border-radius: 1.2rem;
            overflow: hidden;
            position: relative;
            background: radial-gradient(circle at 20% 0%, #ffe0f0, #14051f 92%);
        }

            .hs-product-media img {
                width: 100%;
                display: block;
                object-fit: contain;
                transition: transform .4s ease;
            }

        .hs-product-card:hover .hs-product-media img {
            transform: scale(1.04) translateY(-3px);
        }

        /* ===================== BADGES ===================== */
        .hs-product-badge-sale {
            position: absolute;
            left: .6rem;
            top: .55rem;

        }

            .hs-flash-countdown span.badge {
                border-radius: .7rem;
                padding: .15rem .35rem;
                background: rgba(255, 255, 255, 0.25);
                font-weight: 600;
                min-width: 1.9rem;
                text-align: center;
                color: #fff;
            }

        /* ===================== LINK VIEW ALL ===================== */
        .hs-flash-link-all {
            font-size: .86rem;
            color: #ffe6f3;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: .35rem;
        }

        /* ===================== PRODUCT CARD – HỒNG NHẠT + TÍM ĐẬM ===================== */
        .hs-product-card {
            border-radius: 1.3rem;
            background: linear-gradient(150deg, #fff1f7, #f4e9ff);
            border: 1px solid rgba(88, 28, 135, 0.46);
            padding: .55rem;

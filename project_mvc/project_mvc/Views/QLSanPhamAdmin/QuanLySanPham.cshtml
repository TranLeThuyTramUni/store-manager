@model project_mvc.Models.QuanLySanPhamViewModel

@{
    ViewBag.Title = "Quản lý sản phẩm";
    Layout = "~/Views/Shared/layoutAdmin.cshtml";
    bool isEdit = ViewBag.IsEdit != null && (bool)ViewBag.IsEdit;
}

@section Styles {
    <style>
        /* =========================
           PALETTE & BASE
        ========================== */
        :root {
            --hs-primary: #ec4899;       /* hồng pastel */
            --hs-primary-soft: #fdf2f8;
            --hs-primary-strong: #db2777;
            --hs-border: #e5e7eb;
            --hs-bg-page: #f5f7fb;
            --hs-text-main: #111827;
            --hs-text-muted: #6b7280;
        }

        body {
            background-color: var(--hs-bg-page);
        }

        .page-header-box {
            background: linear-gradient(135deg, #f9a8d4 0%, #ec4899 45%, #db2777 100%);
            padding: 20px 22px;
            border-radius: 18px;
            color: #fff;
            margin-bottom: 22px;
            box-shadow: 0 8px 24px rgba(236, 72, 153, 0.28);
        }

        .page-header-title {
            font-size: 1.4rem;
            font-weight: 700;
            letter-spacing: 0.02em;
        }

        .page-header-sub {
            font-size: 0.9rem;
            opacity: 0.9;
        }

        .page-header-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 4px 10px;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.16);
            font-size: 0.78rem;
        }

        .page-header-badge i {
            font-size: 0.9rem;
        }

        /* =========================
           CARD FORM & TABLE
        ========================== */
        .form-card,
        .table-card {
            background: #ffffff;
            border-radius: 18px;
            padding: 18px 18px 20px;
            border: 1px solid rgba(148, 163, 184, 0.22);
            box-shadow:
                0 18px 40px rgba(15, 23, 42, 0.06),
                0 0 0 1px rgba(255, 255, 255, 0.5);
        }

        .form-card {
            position: relative;
            overflow: hidden;
        }

        .form-card::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at top right, rgba(236, 72, 153, 0.06), transparent 55%);
            pointer-events: none;
        }

        .form-card-inner {
            position: relative;
            z-index: 1;
        }

        .card-title-main {
            font-weight: 650;
            color: var(--hs-text-main);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .card-title-main i {
            color: var(--hs-primary);
        }

        .card-sub-text {
            font-size: 0.8rem;
            color: var(--hs-text-muted);
        }

        .form-label {
            font-weight: 600;
            margin-bottom: 6px;
            color: var(--hs-text-main);
            font-size: 0.9rem;
        }

        .form-control,
        .form-select {
            border-radius: 10px !important;
            border-color: #e5e7eb;
            font-size: 0.9rem;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: var(--hs-primary);
            box-shadow: 0 0 0 1px rgba(236, 72, 153, 0.25);
        }

        .text-danger.small {
            font-size: 0.8rem;
        }

        /* Sticky form bên trái */
        .sticky-form {
            position: sticky;
            top: 84px;
        }

        /* Preview image */
        .img-preview {
            width: 110px;
            height: 110px;
            object-fit: cover;
            border-radius: 16px;
            border: 1px solid #e5e7eb;
            background: #f9fafb;
        }

        .preview-label {
            font-size: 0.78rem;
            color: var(--hs-text-muted);
        }

        /* Danh sách sản phẩm cuộn riêng */
        .product-list-scroll {
            max-height: calc(100vh - 160px);
            overflow-y: auto;
            scrollbar-width: thin;
        }

        .product-list-scroll::-webkit-scrollbar {
            width: 6px;
        }

        .product-list-scroll::-webkit-scrollbar-track {
            background: #f3f4f6;
        }

        .product-list-scroll::-webkit-scrollbar-thumb {
            background: #cbd5f5;
            border-radius: 999px;
        }

        /* Thumbnail table */
        .thumb-img {
            width: 58px;
            height: 58px;
            border-radius: 14px;
            object-fit: cover;
            border: 1px solid #e5e7eb;
            background: #f9fafb;
        }

        .table-hover tbody tr {
            cursor: pointer;
            transition: background-color 0.12s ease, transform 0.05s ease;
        }

        .table-hover tbody tr:hover {
            background-color: #fdf2f8;
        }

        .table > :not(caption) > * > * {
            padding-top: 10px;
            padding-bottom: 10px;
        }

        .table thead th {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: var(--hs-text-muted);
            border-bottom: 1px solid #e5e7eb;
        }

        /* Price & badge */
        .price-text {
            font-weight: 700;
            color: var(--hs-primary-strong);
        }

        .badge-sale {
            background: linear-gradient(135deg, #fb923c, #f97316);
            border-radius: 999px;
            padding: 2px 10px;
            font-size: 0.75rem;
        }

        .badge-sale::before {
            content: "KM ";
            opacity: 0.8;
        }

        /* Buttons */
        .btn-primary {
            background: linear-gradient(135deg, var(--hs-primary), var(--hs-primary-strong));
            border: none;
            border-radius: 999px;
            padding: 7px 16px;
            font-weight: 600;
            font-size: 0.9rem;
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, var(--hs-primary-strong), var(--hs-primary));
        }

        .btn-outline-primary {
            border-radius: 999px;
            font-size: 0.8rem;
            padding: 4px 10px;
            border-color: rgba(236, 72, 153, 0.5);
            color: var(--hs-primary-strong);
        }

        .btn-outline-primary:hover {
            background: var(--hs-primary-soft);
            color: var(--hs-primary-strong);
        }

        .btn-outline-danger {
            border-radius: 999px;
            font-size: 0.8rem;
            padding: 4px 10px;
        }

        .btn-secondary {
            border-radius: 999px;
            font-size: 0.86rem;
        }

        .btn-icon-text i {
            margin-right: 4px;
        }

        /* Search box */
        .search-wrapper {
            max-width: 330px;
            width: 100%;
        }

        .search-input-group .input-group-text {
            border-radius: 999px 0 0 999px;
            border-right: 0;
            background-color: #ffffff;
        }

        .search-input-group .form-control {
            border-radius: 0 999px 999px 0;
            border-left: 0;
            font-size: 0.86rem;
        }

        .search-input-group .btn {
            border-radius: 999px;
            font-size: 0.86rem;
        }

        .search-hint {
            font-size: 0.75rem;
            color: var(--hs-text-muted);
        }

        /* Table action column */
        .cell-actions {
            white-space: nowrap;
        }

        .product-name-main {
            font-weight: 600;
            color: var(--hs-text-main);
            font-size: 0.9rem;
        }

        .product-sub {
            font-size: 0.78rem;
            color: var(--hs-text-muted);
        }

        /* Alert */
        .alert {
            border-radius: 999px;
            padding-top: 8px;
            padding-bottom: 8px;
            font-size: 0.86rem;
        }

        .alert i {
            margin-right: 6px;
        }

        @@media (max-width: 991.98px) {
            .sticky-form {
                position: static;
            }

            .product-list-scroll {
                max-height: none;
            }
        }
        /* Giảm kích thước thumbnail */
        .thumb-img {
            width: 42px !important;
            height: 42px !important;
            border-radius: 10px;
        }

        /* Cột ảnh nhỏ lại */
        .table td:nth-child(2),
        .table th:nth-child(2) {
            width: 60px;
            text-align: center;
        }
        .btn-action-full {
            padding: 6px 14px;
            border-radius: 12px;
            font-size: 0.85rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border: none;
            transition: 0.25s;
        }

        /* Sửa */
        .btn-edit-full {
            background: #fce7f3;
            color: #db2777;
        }

            .btn-edit-full:hover {
                background: #fbcfe8;
                box-shadow: 0 4px 10px rgba(219, 39, 119, 0.25);
            }

        /* Xóa */
        .btn-delete-full {
            background: #fee2e2;
            color: #dc2626;
        }

            .btn-delete-full:hover {
                background: #fecaca;
                box-shadow: 0 4px 10px rgba(220, 38, 38, 0.25);
            }
        /* Cột STT chung */
        .table td.stt-cell {
            width: 44px;
            text-align: center;
            position: relative;
            font-weight: 500;
            font-size: 0.85rem;
            color: #6b7280;
        }

        /* Thanh ngang + đổi màu khi là dòng đang select */
        .table tr.row-selected td.stt-cell {
            color: #db2777; /* màu số */
            font-weight: 700;
        }

            .table tr.row-selected td.stt-cell::after {
                content: "";
                position: absolute;
                left: 6px;
                right: 6px;
                bottom: 3px;
                height: 3px;
                border-radius: 999px;
                background: linear-gradient(90deg, #fb7185, #ec4899, #db2777);
            }

    </style>
}

<div class="page-header-box d-flex justify-content-between align-items-start flex-wrap gap-2">
    <div>
        <div class="page-header-badge mb-1">
            <i class="bi bi-stars"></i>
            <span>Quản lý danh sách sản phẩm</span>
        </div>
        <div class="page-header-title mb-1">
            <i class="bi bi-box-seam me-1"></i> Quản lý sản phẩm
        </div>
        <div class="page-header-sub">
            Thêm, chỉnh sửa thông tin sản phẩm, hình ảnh, danh mục và thương hiệu một cách trực quan.
        </div>
    </div>
</div>

<!-- Thông báo -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4 align-items-start">
    <!-- FORM THÊM / SỬA -->
    <div class="col-lg-4">
        <div class="form-card sticky-form">
            <div class="form-card-inner">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <h5 class="card-title-main mb-1">
                            @if (Model.SanPham.MASP == 0)
                            {
                                <span><i class="bi bi-plus-circle"></i> Thêm sản phẩm mới</span>
                            }
                            else
                            {
                                <span><i class="bi bi-pencil-square"></i> Sửa sản phẩm (#@Model.SanPham.MASP)</span>
                            }
                        </h5>
                        <div class="card-sub-text">
                            Điền đầy đủ thông tin để sản phẩm hiển thị đẹp trên website.
                        </div>
                    </div>
                </div>

                @using (Html.BeginForm("LuuSanPham", "QLSanPhamAdmin", FormMethod.Post,
                            new { enctype = "multipart/form-data", @class = "needs-validation", novalidate = "novalidate" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.SanPham.MASP)
                    @Html.HiddenFor(m => m.SanPham.HINHANH) @* giữ tên file cũ khi không upload mới *@

                    <div class="mb-3">
                        <label class="form-label">Tên sản phẩm</label>
                        @Html.TextBoxFor(m => m.SanPham.TENSP,
                            new { @class = "form-control", placeholder = "Nhập tên sản phẩm", required = "required" })
                        @Html.ValidationMessageFor(m => m.SanPham.TENSP, "", new { @class = "text-danger small" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Giá bán (VND)</label>
                        @Html.TextBoxFor(m => m.SanPham.GIABAN,
                            new
                            {
                                @class = "form-control",
                                type = "text",              // ĐỔI Ở ĐÂY
                                inputmode = "decimal",      // Gợi ý bàn phím số trên mobile
                                placeholder = "VD: 350000"
                            })

                        @Html.ValidationMessageFor(m => m.SanPham.GIABAN, "", new { @class = "text-danger small" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Hình ảnh sản phẩm</label>
                        <input type="file"
                               name="HinhAnhFile"
                               id="HinhAnhFileInput"
                               class="form-control"
                               accept="image/*" />
                        @Html.ValidationMessage("HinhAnhFile", "", new { @class = "text-danger small" })

                        <div class="mt-2 d-flex align-items-center gap-3">
                            <div>
                                <span class="preview-label d-block mb-1">Xem trước</span>
                                @{
                                    var previewPath = string.IsNullOrEmpty(Model.SanPham.HINHANH)
                                        ? Url.Content("~/Images/no-image.png")
                                        : Url.Content("~/Images/" + Model.SanPham.HINHANH);
                                }
                                <img id="previewImage"
                                     class="img-preview"
                                     src="@previewPath"
                                     alt="Preview" />
                            </div>
                            <div class="preview-label">
                                Hỗ trợ định dạng JPG, PNG<br />
                                Kích thước khuyến nghị: vuông, nền sáng.
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Danh mục</label>
                        @Html.DropDownListFor(m => m.SanPham.MADM,
                            Model.DanhMucList,
                            "-- Chọn danh mục --",
                            new { @class = "form-select", required = "required" })
                        @Html.ValidationMessageFor(m => m.SanPham.MADM, "", new { @class = "text-danger small" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Thương hiệu</label>
                        @Html.DropDownListFor(m => m.SanPham.MATH,
                            Model.ThuongHieuList,
                            "-- Chọn thương hiệu --",
                            new { @class = "form-select", required = "required" })
                        @Html.ValidationMessageFor(m => m.SanPham.MATH, "", new { @class = "text-danger small" })
                    </div>

                    <div class="row">
                        <div class="mb-3 col-md-6">
                            <label class="form-label">Số lượng</label>
                            @Html.TextBoxFor(m => m.SanPham.SOLUONG,
                                new { @class = "form-control", type = "number", min = "0" })
                            @Html.ValidationMessageFor(m => m.SanPham.SOLUONG, "", new { @class = "text-danger small" })
                        </div>
                        <div class="mb-3 col-md-6">
                            <label class="form-label">Khuyến mãi (%)</label>
                            @Html.TextBoxFor(m => m.SanPham.KHUYENMAI,
                            new
                            {
                                @class = "form-control",
                                type = "text",          // ĐỔI Ở ĐÂY
                                inputmode = "decimal",
                                placeholder = "VD: 10"
                            })

                            @Html.ValidationMessageFor(m => m.SanPham.KHUYENMAI, "", new { @class = "text-danger small" })
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mô tả sản phẩm</label>
                        @Html.TextAreaFor(m => m.SanPham.MoTa,
                            4, 50,
                            new
                            {
                                @class = "form-control",
                                placeholder = "Mô tả chi tiết công dụng, cách dùng, đối tượng phù hợp..."
                            })
                        @Html.ValidationMessageFor(m => m.SanPham.MoTa, "", new { @class = "text-danger small" })
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <a href="@Url.Action("QuanLySanPham", "QLSanPhamAdmin", new { id = (int?)null })"
                           class="btn btn-secondary btn-sm btn-icon-text">
                            <i class="bi bi-arrow-counterclockwise"></i> Làm mới
                        </a>

                        <button type="submit" class="btn btn-primary btn-sm btn-icon-text">
                            @if (Model.SanPham.MASP == 0)
                            {
                                <span><i class="bi bi-check-circle"></i> Thêm mới</span>
                            }
                            else
                            {
                                <span><i class="bi bi-save"></i> Lưu thay đổi</span>
                            }
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- BẢNG DANH SÁCH -->
    <div class="col-lg-8">
        <div class="table-card product-list-scroll">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                <div>
                    <h5 class="mb-1">
                        <i class="bi bi-list-ul me-1"></i> Danh sách sản phẩm
                    </h5>
                    <div class="search-hint">
                        Nhấp vào một dòng để chỉnh sửa nhanh thông tin.
                    </div>
                </div>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <div class="search-wrapper">
                        @using (Html.BeginForm("QuanLySanPham", "QLSanPhamAdmin", FormMethod.Get))
                        {
                            <div class="input-group search-input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-search"></i>
                                </span>
                                <input type="text"
                                       name="search"
                                       value="@Request["search"]"
                                       class="form-control"
                                       placeholder="Tìm theo tên, mã sản phẩm...">
                                <button class="btn btn-outline-secondary btn-sm">
                                    Tìm
                                </button>
                            </div>
                        }
                    </div>

                    <a href="@Url.Action("QuanLySanPham", "QLSanPhamAdmin", new { id = (int?)null })"
                       class="btn btn-primary btn-sm btn-icon-text">
                        <i class="bi bi-plus-circle"></i> Thêm sản phẩm
                    </a>
                </div>
            </div>

            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Ảnh</th>
                        <th>Sản phẩm</th>
                        <th>Danh mục</th>
                        <th>Thương hiệu</th>
                        <th>Giá bán</th>
                        <th>KM</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.DanhSach != null && Model.DanhSach.Any())
                    {
                        int stt = 1;
                        foreach (var item in Model.DanhSach)
                        {
                            var imgPath = string.IsNullOrEmpty(item.HINHANH)
                                ? Url.Content("~/Images/no-image.png")
                                : Url.Content("~/Images/" + item.HINHANH);

                            // xác định dòng hiện đang được chọn (đang sửa)
                            var isSelected = Model.SanPham != null && item.MASP == Model.SanPham.MASP;

                            <tr class="@(isSelected ? "row-selected" : "")"
                                onclick="window.location='@Url.Action("QuanLySanPham", "QLSanPhamAdmin", new { id = item.MASP })'">

                                <td class="stt-cell">@stt</td>

                                <td>
                                    <img src="@imgPath" alt="Ảnh @item.TENSP" class="thumb-img" />
                                </td>
                                <td>
                                    <div class="product-name-main">@item.TENSP</div>
                                    <div class="product-sub">Mã: @item.MASP</div>
                                </td>
                                <td>@(item.DANHMUC != null ? item.DANHMUC.TENDANHMUC : item.MADM)</td>
                                <td>@(item.THUONGHIEU != null ? item.THUONGHIEU.TENTH : item.MATH.ToString())</td>
                                <td class="price-text">
                                    @item.GIABAN.ToString("N0") đ
                                </td>
                                <td>
                                    @if (item.KHUYENMAI > 0)
                                    {
                                        <span class="badge badge-sale text-white">@item.KHUYENMAI %</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-end cell-actions">
                                    <a href="@Url.Action("QuanLySanPham", "QLSanPhamAdmin", new { id = item.MASP })"
                                       class="btn-action-full btn-edit-full me-1"
                                       title="Sửa"
                                       onclick="event.stopPropagation();">
                                        <i class="bi bi-pencil-fill"></i> Sửa
                                    </a>

                                    @using (Html.BeginForm("XoaSanPham", "QLSanPhamAdmin", FormMethod.Post,
                                        new { onsubmit = "return confirm('Xóa sản phẩm này?');", @class = "d-inline" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        @Html.Hidden("id", item.MASP)
                                        <button type="submit"
                                                class="btn-action-full btn-delete-full"
                                                title="Xóa"
                                                onclick="event.stopPropagation();">
                                            <i class="bi bi-trash-fill"></i> Xóa
                                        </button>
                                    }
                                </td>
                            </tr>
                            stt++;
                        }
                    }

                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                Chưa có sản phẩm nào trong hệ thống.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Xem trước ảnh khi chọn file
        document.addEventListener("DOMContentLoaded", function () {
            var input = document.getElementById("HinhAnhFileInput");
            var preview = document.getElementById("previewImage");

            if (input && preview) {
                input.addEventListener("change", function () {
                    if (this.files && this.files[0]) {
                        var reader = new FileReader();
                        reader.onload = function (e) {
                            preview.src = e.target.result;
                        };
                        reader.readAsDataURL(this.files[0]);
                    }
                });
            }
        });
    </script>
}

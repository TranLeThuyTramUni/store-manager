@model project_mvc.Models.CamNangLamDepViewModel

@{
    ViewBag.Title = "Quản lý bài viết";
    Layout = "~/Views/Shared/layoutAdmin.cshtml";
    bool isEdit = ViewBag.IsEdit != null && (bool)ViewBag.IsEdit;
    int total = Model.DanhSach != null ? Model.DanhSach.Count() : 0;
}

@section Styles {
    <style>
        /* =========================
           PALETTE & BASE
        ========================== */
        :root {
            --hs-primary: #ec4899; /* hồng pastel */
            --hs-primary-soft: #fdf2f8;
            --hs-primary-strong: #db2777;
            --hs-border: #e5e7eb;
            --hs-bg-page: #f5f7fb;
            --hs-text-main: #111827;
            --hs-text-muted: #6b7280;
        }

        body {
            background-color: var(--hs-bg-page);
        }

        /* =========================
           HEADER
        ========================== */
        .page-header-box {
            background: linear-gradient(135deg, #f9a8d4 0%, #ec4899 45%, #db2777 100%);
            padding: 20px 22px;
            border-radius: 18px;
            color: #fff;
            margin-bottom: 22px;
            box-shadow: 0 8px 24px rgba(236, 72, 153, 0.28);
            position: relative;
            overflow: hidden;
        }

            .page-header-box::after {
                content: "";
                position: absolute;
                inset: 0;
                background: radial-gradient(circle at 0% 0%, rgba(255,255,255,.32) 0, transparent 55%), radial-gradient(circle at 100% 100%, rgba(251,113,133,.32) 0, transparent 60%);
                opacity: .7;
                pointer-events: none;
            }

        .page-header-inner {
            position: relative;
            z-index: 1;
        }

        .page-header-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 4px 10px;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.16);
            font-size: 0.78rem;
        }

            .page-header-badge i {
                font-size: 0.9rem;
            }

        .page-header-title {
            font-size: 1.4rem;
            font-weight: 700;
            letter-spacing: 0.02em;
            display: flex;
            align-items: center;
            gap: .65rem;
        }

            .page-header-title i {
                font-size: 1.3rem;
            }

        .page-header-sub {
            font-size: 0.9rem;
            opacity: 0.9;
            margin-top: 0.2rem;
        }

        .page-header-stat {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 4px 10px;
            border-radius: 999px;
            background: rgba(15,23,42,.18);
            font-size: 0.8rem;
            margin-top: 0.6rem;
        }

            .page-header-stat span.badge {
                background: rgba(15,23,42,.9);
                border-radius: 999px;
            }

        /* =========================
           CARD FORM & TABLE
        ========================== */
        .form-card,
        .table-card {
            background: #ffffff;
            border-radius: 18px;
            padding: 18px 18px 20px;
            border: 1px solid rgba(148, 163, 184, 0.22);
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.06), 0 0 0 1px rgba(255, 255, 255, 0.5);
        }

        /* Sticky form bên trái */
        .sticky-form {
            position: sticky;
            top: 84px;
        }

        .form-card {
            position: relative;
            overflow: hidden;
        }

            .form-card::before {
                content: "";
                position: absolute;
                inset: 0;
                background: radial-gradient(circle at top right, rgba(236, 72, 153, 0.06), transparent 55%);
                pointer-events: none;
            }

        .form-card-inner {
            position: relative;
            z-index: 1;
        }

        .card-title-main {
            font-weight: 650;
            color: var(--hs-text-main);
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .card-title-main i {
                color: var(--hs-primary);
            }

        .card-sub-text {
            font-size: 0.8rem;
            color: var(--hs-text-muted);
        }

        .form-label {
            font-weight: 600;
            margin-bottom: 6px;
            color: var(--hs-text-main);
            font-size: 0.9rem;
        }

        .form-control,
        .form-select,
        textarea.form-control {
            border-radius: 10px !important;
            border-color: #e5e7eb;
            font-size: 0.9rem;
        }

            .form-control:focus,
            .form-select:focus,
            textarea.form-control:focus {
                border-color: var(--hs-primary);
                box-shadow: 0 0 0 1px rgba(236, 72, 153, 0.25);
            }

        .text-danger.small {
            font-size: 0.8rem;
        }

        .form-hint {
            font-size: 0.8rem;
            color: var(--hs-text-muted);
        }

        /* Danh sách bài viết cuộn riêng */
        .post-list-scroll {
            max-height: calc(100vh - 160px);
            overflow-y: auto;
            scrollbar-width: thin;
        }

            .post-list-scroll::-webkit-scrollbar {
                width: 6px;
            }

            .post-list-scroll::-webkit-scrollbar-track {
                background: #f3f4f6;
            }

            .post-list-scroll::-webkit-scrollbar-thumb {
                background: #cbd5f5;
                border-radius: 999px;
            }

        /* TABLE */
        .table-hover tbody tr {
            cursor: pointer;
            transition: background-color 0.12s ease, transform 0.05s ease;
        }

            .table-hover tbody tr:hover {
                background-color: #fdf2f8;
            }

        .table > :not(caption) > * > * {
            padding-top: 10px;
            padding-bottom: 10px;
        }

        .table thead th {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: var(--hs-text-muted);
            border-bottom: 1px solid #e5e7eb;
        }

        /* Cột STT */
        .table td.stt-cell {
            width: 44px;
            text-align: center;
            position: relative;
            font-weight: 500;
            font-size: 0.85rem;
            color: #6b7280;
        }

        /* Thanh ngang + đổi màu khi là dòng đang select */
        .table tr.row-selected td.stt-cell {
            color: #db2777; /* màu số */
            font-weight: 700;
        }

            .table tr.row-selected td.stt-cell::after {
                content: "";
                position: absolute;
                left: 6px;
                right: 6px;
                bottom: 3px;
                height: 3px;
                border-radius: 999px;
                background: linear-gradient(90deg, #fb7185, #ec4899, #db2777);
            }

        /* Ảnh thumb & preview */
        .thumb-img {
            width: 80px;
            height: 60px;
            object-fit: cover;
            border-radius: 8px;
        }

        .img-preview {
            width: 120px;
            height: 90px;
            object-fit: cover;
            border-radius: 10px;
            border: 1px solid var(--hs-border);
        }

        /* Buttons */
        .btn-primary {
            background: linear-gradient(135deg, var(--hs-primary), var(--hs-primary-strong));
            border: none;
            border-radius: 999px;
            padding: 7px 16px;
            font-weight: 600;
            font-size: 0.9rem;
        }

            .btn-primary:hover {
                background: linear-gradient(135deg, var(--hs-primary-strong), var(--hs-primary));
            }

        .btn-secondary {
            border-radius: 999px;
            font-size: 0.86rem;
        }

        .btn-icon-text i {
            margin-right: 4px;
        }

        .btn-action-full {
            padding: 6px 14px;
            border-radius: 12px;
            font-size: 0.85rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border: none;
            transition: 0.25s;
        }

        /* Sửa */
        .btn-edit-full {
            background: #fce7f3;
            color: #db2777;
        }

            .btn-edit-full:hover {
                background: #fbcfe8;
                box-shadow: 0 4px 10px rgba(219, 39, 119, 0.25);
            }

        /* Xóa */
        .btn-delete-full {
            background: #fee2e2;
            color: #dc2626;
        }

            .btn-delete-full:hover {
                background: #fecaca;
                box-shadow: 0 4px 10px rgba(220, 38, 38, 0.25);
            }

        /* Alert pill */
        .alert {
            border-radius: 999px;
            padding-top: 8px;
            padding-bottom: 8px;
            font-size: 0.86rem;
        }

            .alert i {
                margin-right: 6px;
            }

        @@media (max-width: 991.98px) {
            .sticky-form {
                position: static;
            }

            .post-list-scroll {
                max-height: none;
            }
        }
    </style>
}

<div class="page-header-box">
    <div class="page-header-inner d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <div class="page-header-badge mb-1">
                <i class="bi bi-journal-text"></i>
                <span>Quản lý Cẩm Nang Làm Đẹp</span>
            </div>
            <div class="page-header-title mb-1">
                <i class="bi bi-brush-fill"></i>
                <span>Quản lý bài viết</span>
            </div>
            <div class="page-header-sub">
                Thêm, chỉnh sửa các bài viết chia sẻ kiến thức skincare, makeup, tips làm đẹp.
            </div>
            <div class="page-header-stat">
                <i class="bi bi-file-earmark-text"></i>
                <span>Đang có</span>
                <span class="badge text-bg-light">@total bài viết</span>
            </div>
        </div>
    </div>
</div>

<!-- Thông báo -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4 align-items-start">
    <!-- FORM THÊM / SỬA -->
    <div class="col-lg-4">
        <div class="form-card sticky-form">
            <div class="form-card-inner">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <h5 class="card-title-main mb-1">
                            @if (Model.BaiViet.Id == 0)
                            {
                                <span><i class="bi bi-plus-circle"></i> Thêm bài viết mới</span>
                            }
                            else
                            {
                                <span><i class="bi bi-pencil-square"></i> Sửa bài viết (#@Model.BaiViet.Id)</span>
                            }
                        </h5>
                        <div class="card-sub-text">
                            Viết tiêu đề, mô tả và nội dung hấp dẫn để thu hút người đọc.
                        </div>
                    </div>
                </div>

                @using (Html.BeginForm("LuuBaiViet", "QLBaiVietAdmin", FormMethod.Post, new { enctype = "multipart/form-data" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.BaiViet.Id)
                    @Html.HiddenFor(m => m.BaiViet.ImageUrl) <!-- giữ ảnh cũ -->

                    <div class="mb-3">
                        <label class="form-label">Tiêu đề</label>
                        @Html.TextBoxFor(m => m.BaiViet.Title,
                            new
                            {
                                @class = "form-control",
                                placeholder = "Nhập tiêu đề bài viết"
                            })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mô tả ngắn</label>
                        @Html.TextAreaFor(m => m.BaiViet.ShortDescription,
                            3, 50,
                            new
                            {
                                @class = "form-control",
                                placeholder = "Tóm tắt nội dung chính để hiển thị ở danh sách"
                            })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Nội dung bài viết</label>
                        @Html.TextAreaFor(m => m.BaiViet.Content,
                            6, 50,
                            new
                            {
                                @class = "form-control",
                                placeholder = "Nhập nội dung chi tiết (có thể dùng HTML để định dạng)"
                            })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Hình đại diện</label>
                        <input type="file"
                               name="ImageFile"
                               class="form-control"
                               accept="image/*" />

                        <div class="mt-2">
                            <span class="text-muted small d-block mb-1">Xem trước:</span>
                            <img class="img-preview"
                                 src="@(String.IsNullOrEmpty(Model.BaiViet.ImageUrl)
                                      ? Url.Content("~/Images/no-image.png")
                                      : Url.Content(Model.BaiViet.ImageUrl))" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Danh mục</label>
                        @Html.TextBoxFor(m => m.BaiViet.Category,
                            new
                            {
                                @class = "form-control",
                                placeholder = "VD: Chăm sóc da, Trang điểm, Tips làm đẹp..."
                            })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Ngày đăng</label>
                        @Html.TextBoxFor(m => m.BaiViet.PostDate,
                            new
                            {
                                @class = "form-control",
                                placeholder = "VD: 10/02/2025"
                            })
                    </div>

                    <div class="d-flex justify-content-between gap-2 mt-3">
                        <a href="@Url.Action("QuanLyBaiViet", "QLBaiVietAdmin")"
                           class="btn btn-secondary btn-icon-text flex-fill">
                            <i class="bi bi-arrow-counterclockwise"></i> Làm mới
                        </a>

                        <button type="submit" class="btn btn-primary btn-icon-text flex-fill">
                            @if (Model.BaiViet.Id == 0)
                            {
                                <span><i class="bi bi-check-circle"></i> Thêm mới</span>
                            }
                            else
                            {
                                <span><i class="bi bi-save"></i> Lưu thay đổi</span>
                            }
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- DANH SÁCH BÀI VIẾT -->
    <div class="col-lg-8">
        <div class="table-card post-list-scroll">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                <div>
                    <h5 class="mb-1">
                        <i class="bi bi-list-ul me-1"></i> Danh sách bài viết
                    </h5>
                    <div class="card-sub-text">
                        Nhấp vào một dòng để xem hoặc chỉnh sửa nội dung chi tiết.
                    </div>
                </div>

                <a href="@Url.Action("QuanLyBaiViet", "QLBaiVietAdmin")"
                   class="btn btn-primary btn-icon-text btn-sm">
                    <i class="bi bi-plus-circle"></i> Thêm bài viết
                </a>
            </div>

            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Ảnh</th>
                        <th>Tiêu đề</th>
                        <th>Danh mục</th>
                        <th>Ngày đăng</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.DanhSach != null && Model.DanhSach.Any())
                    {
                        int stt = 1;
                        foreach (var item in Model.DanhSach)
                        {
                            var isSelectedRow = Model.BaiViet != null && item.Id == Model.BaiViet.Id;

                            <tr class="@(isSelectedRow ? "row-selected" : "")"
                                onclick="window.location='@Url.Action("QuanLyBaiViet", "QLBaiVietAdmin", new { id = item.Id })'">
                                <td class="stt-cell">@stt</td>
                                <td>
                                    <img src="@(String.IsNullOrEmpty(item.ImageUrl)
                                            ? Url.Content("~/Images/no-image.png")
                                            : Url.Content(item.ImageUrl))"
                                         class="thumb-img" />
                                </td>
                                <td>@item.Title</td>
                                <td>@item.Category</td>
                                <td>@item.PostDate</td>
                                <td class="text-end">
                                    <a href="@Url.Action("QuanLyBaiViet", "QLBaiVietAdmin", new { id = item.Id })"
                                       class="btn-action-full btn-edit-full me-1"
                                       onclick="event.stopPropagation();"
                                       title="Sửa bài viết">
                                        <i class="bi bi-pencil-fill"></i> Sửa
                                    </a>

                                    @using (Html.BeginForm("XoaBaiViet", "QLBaiVietAdmin", FormMethod.Post,
                                        new { onsubmit = "return confirm('Bạn có chắc muốn xóa bài này?');", @class = "d-inline" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        @Html.Hidden("id", item.Id)
                                        <button type="submit"
                                                class="btn-action-full btn-delete-full"
                                                onclick="event.stopPropagation();"
                                                title="Xóa bài viết">
                                            <i class="bi bi-trash-fill"></i> Xóa
                                        </button>
                                    }
                                </td>
                            </tr>
                            stt++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="bi bi-inboxes me-1"></i> Chưa có bài viết nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

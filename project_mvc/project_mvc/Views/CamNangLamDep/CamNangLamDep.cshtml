@model IEnumerable<project_mvc.Models.CamNangLamDep>
@{
    Layout = "~/Views/Shared/View.cshtml";
    ViewData["Title"] = "Cẩm nang làm đẹp";
}

<div class="news-page py-4">
    <div class="container">
        <div class="row">
            <!-- MAIN -->
            <div class="col-lg-8">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h2 class="section-title mb-0">Cẩm nang làm đẹp</h2>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0 bg-transparent p-0">
                            <li class="breadcrumb-item"><a href="/Home/About">Trang chủ</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Cẩm nang làm đẹp</li>
                        </ol>
                    </nav>
                </div>

                <div class="row g-3">
                    @foreach (var a in Model)
                    {
                        <div class="col-md-6">
                            <article class="card news-card h-100">
                                <a href="@Url.Action("ChiTiet","CamNangLamDep", new { id = a.Id })" class="thumb-link d-block">
                                    <img src="@(a.ImageUrl ?? "/images/default-post.jpg")" alt="@a.Title" class="card-img-top news-thumb" />
                                </a>

                                <div class="card-body">
                                    <div class="meta small text-muted mb-1">
                                        <span class="me-2">@a.Category</span>
                                        <span>@a.PostDate</span>
                                    </div>

                                    <h5 class="card-title mb-2">
                                        <a href="@Url.Action("ChiTiet","CamNangLamDep", new { id = a.Id })"
                                           class="text-decoration-none text-dark">
                                            @a.Title
                                        </a>
                                    </h5>

                                    <p class="card-text text-truncate-3">@a.ShortDescription</p>

                                    <a href="@Url.Action("ChiTiet","CamNangLamDep", new { id = a.Id })"
                                       class="btn btn-link px-0">Xem chi tiết →</a>
                                </div>
                            </article>
                        </div>
                    }
                </div>

                <!-- Pagination mẫu -->
                <nav class="mt-4" aria-label="Page navigation">
                    <ul class="pagination justify-content-center">

                        <li class="page-item @(ViewBag.Page == 1 ? "disabled" : "")">
                            <a class="page-link" href="?page=@(ViewBag.Page - 1)">«</a>
                        </li>

                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(ViewBag.Page == i ? "active" : "")">
                                <a class="page-link" href="?page=@i">@i</a>
                            </li>
                        }

                        <li class="page-item @(ViewBag.Page == ViewBag.TotalPages ? "disabled" : "")">
                            <a class="page-link" href="?page=@(ViewBag.Page + 1)">»</a>
                        </li>

                    </ul>
                </nav>

            </div>

            <!-- SIDEBAR -->
            <aside class="col-lg-4">
                <div class="sticky-top" style="top:20px">

                    <!-- Bài viết nổi bật -->
                    <div class="card mb-3">
                        <div class="card-body">
                            <h6 class="mb-2">Bài viết nổi bật</h6>
                            <div class="list-group list-group-flush">

                                @foreach (var top in Model.Take(3))
                                {
                                    <a href="@Url.Action("ChiTiet","CamNangLamDep", new { id = top.Id })"
                                       class="list-group-item list-group-item-action d-flex gap-3 align-items-center">
                                        <img src="@(top.ImageUrl ?? "/images/post-sm.jpg")"
                                             style="width:84px;height:64px;object-fit:cover;border-radius:6px" />

                                        <div class="small">
                                            <div class="fw-bold text-truncate" style="max-width:160px">
                                                @top.Title
                                            </div>
                                            <div class="text-muted small">@top.PostDate</div>
                                        </div>
                                    </a>
                                }

                            </div>
                        </div>
                    </div>

                    <!-- Danh mục -->
                    <div class="card mb-3">
                        <div class="card-body">
                            <h6 class="mb-2">Danh mục</h6>
                            <ul class="list-unstyled mb-0">
                                <li>
                                    <a href="@Url.Action("DanhMuc","CamNangLamDep", new { name = "Chăm sóc da" })"
                                       class="sidebar-link d-block py-1">Chăm sóc da</a>
                                </li>

                                <li>
                                    <a href="@Url.Action("DanhMuc","CamNangLamDep", new { name = "Sản phẩm mới" })"
                                       class="sidebar-link d-block py-1">Sản phẩm mới</a>
                                </li>

                                <li>
                                    <a href="@Url.Action("DanhMuc","CamNangLamDep", new { name = "Mẹo làm đẹp" })"
                                       class="sidebar-link d-block py-1">Mẹo làm đẹp</a>
                                </li>

                            </ul>
                        </div>
                    </div>

                </div>
            </aside>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* =========================================================
           CẨM NANG LÀM ĐẸP – NEWS PAGE THE FACE SHOP
           Tông hồng nhẹ, sang, mềm – style đồng bộ site chính
           ---------------------------------------------------------
           Gợi ý: nếu muốn chỉnh màu, sửa ở :root bên dưới
        ========================================================== */

        :root {
            --news-bg: #fdf2f8;
            --news-bg-soft: #fef7fb;
            --news-primary: #ec407a;
            --news-primary-soft: #f48fb1;
            --news-primary-deep: #d81b60;
            --news-accent: #ffb74d;
            --news-border: rgba(148, 163, 184, 0.25);
            --news-border-soft: rgba(148, 163, 184, 0.16);
            --news-text: #111827;
            --news-text-soft: #6b7280;
            --news-radius-lg: 1.25rem;
            --news-radius-md: 0.85rem;
            --news-radius-pill: 999px;
            --news-shadow-soft: 0 18px 45px rgba(15, 23, 42, 0.12);
            --news-shadow-card: 0 14px 35px rgba(15, 23, 42, 0.10);
            --news-shadow-subtle: 0 10px 25px rgba(15, 23, 42, 0.06);
        }

        /* =========================================================
           1. NỀN TỔNG THỂ & WRAPPER
        ========================================================== */

        .news-page {
            background: radial-gradient(circle at top left, rgba(248, 187, 208, 0.55) 0, transparent 52%), radial-gradient(circle at bottom right, rgba(187, 222, 251, 0.55) 0, transparent 54%), linear-gradient(180deg, #ffffff 0%, var(--news-bg) 48%, #ffffff 100%);
            min-height: calc(100vh - 80px);
        }

            .news-page .container {
                position: relative;
            }

                .news-page .container::before {
                    content: "";
                    position: absolute;
                    inset: 0;
                    background: radial-gradient(circle at 12% 0%, rgba(255, 255, 255, 0.8) 0, transparent 50%), radial-gradient(circle at 100% 100%, rgba(236, 72, 153, 0.12) 0, transparent 60%);
                    opacity: 0.7;
                    pointer-events: none;
                    z-index: -1;
                }

            /* =========================================================
           2. TIÊU ĐỀ KHU VỰC + BREADCRUMB
        ========================================================== */

            .news-page .section-title {
                font-size: 1.6rem;
                font-weight: 800;
                letter-spacing: .02em;
                color: #111827;
                display: inline-flex;
                align-items: center;
                gap: .55rem;
            }

                .news-page .section-title::before {
                    content: "";
                    display: inline-block;
                    width: 34px;
                    height: 34px;
                    border-radius: 50%;
                    background: radial-gradient(circle at 30% 0%, #fff 0, rgba(255, 255, 255, 0.2) 45%), linear-gradient(135deg, var(--news-primary) 0%, var(--news-primary-soft) 45%, var(--news-accent) 100%);
                    box-shadow: 0 10px 25px rgba(236, 72, 153, 0.35);
                }

                .news-page .section-title + nav {
                    font-size: .82rem;
                }

            .news-page .breadcrumb {
                margin-bottom: 0;
                padding: .45rem .7rem;
                background-color: rgba(255, 255, 255, 0.65);
                border-radius: 999px;
                border: 1px solid rgba(248, 113, 113, 0.14);
                backdrop-filter: blur(14px);
            }

            .news-page .breadcrumb-item + .breadcrumb-item::before {
                color: rgba(148, 163, 184, 0.9);
            }

            .news-page .breadcrumb-item a {
                color: #4b5563;
                text-decoration: none;
                transition: color .15s ease, transform .15s ease;
            }

                .news-page .breadcrumb-item a:hover {
                    color: var(--news-primary-deep);
                    transform: translateY(-1px);
                }

            .news-page .breadcrumb-item.active {
                color: #111827;
                font-weight: 600;
            }

            /* =========================================================
           3. LƯỚI BÀI VIẾT CHÍNH
        ========================================================== */

            .news-page .row > .col-lg-8 {
                margin-bottom: 1.5rem;
            }

        .news-card {
            position: relative;
            border-radius: var(--news-radius-lg);
            border: 1px solid var(--news-border-soft);
            background: radial-gradient(circle at top, #ffffff 0%, var(--news-bg-soft) 120%);
            overflow: hidden;
            transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
            box-shadow: 0 0 0 rgba(15, 23, 42, 0);
        }

            .news-card::before {
                content: "";
                position: absolute;
                inset: 0;
                background: radial-gradient(circle at 0% 0%, rgba(255, 255, 255, 0.22) 0, transparent 55%), radial-gradient(circle at 110% 0%, rgba(236, 72, 153, 0.20) 0, transparent 58%);
                opacity: 0;
                transition: opacity .2s ease;
                pointer-events: none;
            }

            .news-card:hover {
                transform: translateY(-8px);
                border-color: rgba(236, 72, 153, 0.32);
                box-shadow: var(--news-shadow-card);
            }

                .news-card:hover::before {
                    opacity: 1;
                }

            .news-card .card-body {
                position: relative;
                z-index: 1;
                padding: 1.05rem 1.1rem 1.1rem;
            }

                .news-card .card-body::before {
                    content: "";
                    position: absolute;
                    inset: 0;
                    border-radius: inherit;
                    background: linear-gradient(180deg, transparent 0%, rgba(255, 255, 255, 0.2) 38%, transparent 100%);
                    opacity: 0;
                    transition: opacity .18s ease;
                    pointer-events: none;
                }

            .news-card:hover .card-body::before {
                opacity: 1;
            }

        /* =========================================================
           4. ẢNH BÌA & LINK
        ========================================================== */

        .news-page .thumb-link {
            display: block;
            position: relative;
            overflow: hidden;
        }

            .news-page .thumb-link::after {
                content: "";
                position: absolute;
                inset: 0;
                background: linear-gradient(180deg, transparent 10%, rgba(15, 23, 42, 0.18) 100%);
                opacity: 0;
                transition: opacity .2s ease;
            }

        .news-card:hover .thumb-link::after {
            opacity: 1;
        }

        .news-thumb {
            width: 100%;
            height: 210px;
            object-fit: cover;
            transition: transform .3s ease;
        }

        .news-card:hover .news-thumb {
            transform: scale(1.05);
        }

        /* =========================================================
           5. META (CATEGORY + DATE)
        ========================================================== */

        .news-card .meta {
            display: flex;
            align-items: center;
            gap: .35rem;
            flex-wrap: wrap;
            color: var(--news-text-soft);
        }

            .news-card .meta span {
                display: inline-flex;
                align-items: center;
                gap: .3rem;
            }

                .news-card .meta span:first-child::before {
                    content: "";
                    width: 6px;
                    height: 6px;
                    border-radius: 50%;
                    background: linear-gradient(135deg, var(--news-primary) 0%, var(--news-accent) 100%);
                }

                .news-card .meta span:last-child::before {
                    content: "\f073";
                    font-family: "Font Awesome 6 Free";
                    font-weight: 900;
                    font-size: .7rem;
                    color: rgba(107, 114, 128, 0.9);
                }

        /* =========================================================
           6. TIÊU ĐỀ & MÔ TẢ TÓM TẮT
        ========================================================== */

        .news-card .card-title {
            font-size: 1.02rem;
            font-weight: 700;
            line-height: 1.35;
            margin-bottom: .45rem;
        }

            .news-card .card-title a {
                color: var(--news-text);
                text-decoration: none;
                transition: color .16s ease;
            }

        .news-card:hover .card-title a {
            color: var(--news-primary-deep);
        }

        .news-card .card-text {
            font-size: .88rem;
            color: var(--news-text-soft);
            margin-bottom: .6rem;
        }

        .text-truncate-3 {
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        /* =========================================================
           7. LINK “XEM CHI TIẾT”
        ========================================================== */

        .news-card .btn-link {
            font-size: .86rem;
            padding: 0;
            font-weight: 600;
            color: var(--news-primary-deep);
            display: inline-flex;
            align-items: center;
            gap: .3rem;
            text-decoration: none;
            position: relative;
        }

            .news-card .btn-link::after {
                content: "";
                position: absolute;
                left: 0;
                bottom: -2px;
                width: 0;
                height: 1.5px;
                border-radius: 999px;
                background: linear-gradient(90deg, var(--news-primary), var(--news-accent));
                transition: width .2s ease;
            }

            .news-card .btn-link:hover::after {
                width: 100%;
            }

            .news-card .btn-link:hover {
                color: var(--news-primary);
            }

        /* =========================================================
           8. LINK TRONG KHU CẨM NANG (KHÔNG ĐỤNG GLOBAL)
        ========================================================== */

        .news-page a {
            color: inherit;
            text-decoration: none;
        }

            .news-page a:hover {
                text-decoration: none;
            }

        /* =========================================================
           9. PHÂN TRANG – PAGINATION
        ========================================================== */

        .news-page .pagination {
            gap: .35rem;
        }

        .news-page .page-item .page-link {
            border-radius: 999px !important;
            min-width: 2.4rem;
            height: 2.4rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: .86rem;
            border: 1px solid rgba(148, 163, 184, 0.5);
            color: #4b5563;
            background-color: #ffffff;
            box-shadow: 0 6px 16px rgba(148, 163, 184, 0.15);
            transition: background-color .16s ease, color .16s ease, transform .16s ease, box-shadow .16s ease, border-color .16s ease;
        }

        .news-page .page-item:first-child .page-link,
        .news-page .page-item:last-child .page-link {
            padding-inline: .7rem;
        }

        .news-page .page-item .page-link:hover {
            background: linear-gradient(135deg, var(--news-primary) 0%, var(--news-accent) 100%);
            color: #ffffff;
            border-color: transparent;
            transform: translateY(-2px);
            box-shadow: 0 12px 25px rgba(236, 72, 153, 0.4);
        }

        .news-page .page-item.active .page-link {
            background: linear-gradient(135deg, var(--news-primary) 0%, var(--news-primary-soft) 100%);
            border-color: transparent;
            color: #ffffff;
            font-weight: 700;
        }

        .news-page .page-item.disabled .page-link {
            opacity: .5;
            cursor: default;
            box-shadow: none;
            background-color: rgba(249, 250, 251, 0.9);
        }

        /* =========================================================
           10. SIDEBAR – KHỐI DÍNH & CARD
        ========================================================== */

        .news-page aside .sticky-top {
            z-index: 2;
        }

        .news-page aside .card {
            border-radius: var(--news-radius-md);
            border: 1px solid rgba(148, 163, 184, 0.3);
            box-shadow: var(--news-shadow-subtle);
            background: radial-gradient(circle at top left, #ffffff 0%, #f9fafb 55%);
            overflow: hidden;
        }

            .news-page aside .card + .card {
                margin-top: 1rem;
            }

        .news-page aside .card-body {
            padding: 1rem 1rem 1.05rem;
        }

        .news-page aside h6 {
            font-size: .92rem;
            text-transform: uppercase;
            letter-spacing: .16em;
            font-weight: 700;
            color: #4b5563;
            margin-bottom: .75rem;
        }

            .news-page aside h6::after {
                content: "";
                display: inline-block;
                margin-left: .65rem;
                width: 38px;
                height: 2px;
                border-radius: 999px;
                background: linear-gradient(90deg, var(--news-primary), var(--news-accent));
                vertical-align: middle;
            }

        /* =========================================================
           11. BÀI VIẾT NỔI BẬT – LIST GROUP
        ========================================================== */

        .news-page .list-group {
            margin: 0;
        }

        .news-page .list-group-item {
            border: 0;
            padding: .45rem 0;
            border-radius: .7rem;
            transition: background-color .15s ease, transform .15s ease;
        }

            .news-page .list-group-item + .list-group-item {
                margin-top: .1rem;
            }

            .news-page .list-group-item img {
                flex-shrink: 0;
                border-radius: .6rem;
                object-fit: cover;
                box-shadow: 0 8px 18px rgba(15, 23, 42, 0.25);
            }

            .news-page .list-group-item .fw-bold {
                font-size: .86rem;
                color: #111827;
            }

            .news-page .list-group-item .text-muted {
                font-size: .78rem;
            }

            .news-page .list-group-item:hover {
                background-color: rgba(248, 250, 252, 0.95);
                transform: translateY(-3px);
            }

        /* =========================================================
           12. DANH MỤC – CATEGORY LINK
        ========================================================== */

        .sidebar-link {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: .75rem;
            padding-block: .35rem;
            font-size: .88rem;
            color: #111827 !important;
            text-decoration: none !important;
            border-radius: .65rem;
            padding-inline: .35rem;
            position: relative;
            transition: background-color .18s ease, color .18s ease, transform .18s ease, box-shadow .18s ease;
        }

            .sidebar-link::before {
                content: "";
                width: 8px;
                height: 8px;
                border-radius: 50%;
                background: radial-gradient(circle at 30% 0%, #fff 0, rgba(255, 255, 255, 0.2) 45%), linear-gradient(135deg, var(--news-primary), var(--news-accent));
                box-shadow: 0 0 0 3px rgba(236, 72, 153, 0.18);
            }

            .sidebar-link::after {
                content: "\f105";
                font-family: "Font Awesome 6 Free";
                font-weight: 900;
                font-size: .72rem;
                color: rgba(148, 163, 184, 0.9);
                opacity: 0;
                transform: translateX(-4px);
                transition: opacity .18s ease, transform .18s ease;
            }

            .sidebar-link span {
                flex: 1;
            }

            .sidebar-link:hover {
                background: linear-gradient(90deg, rgba(236, 72, 153, 0.08), rgba(251, 191, 36, 0.04));
                color: var(--news-primary-deep) !important;
                transform: translateY(-1px);
                box-shadow: 0 10px 22px rgba(15, 23, 42, 0.06);
            }

                .sidebar-link:hover::after {
                    opacity: 1;
                    transform: translateX(0);
                }

        /* List không chấm */
        .news-page ul.list-unstyled {
            margin-bottom: 0;
        }

            .news-page ul.list-unstyled li + li {
                margin-top: .1rem;
            }

        /* =========================================================
           13. HIỆU ỨNG NHẸ CHO COL
        ========================================================== */

        .news-page .col-md-6 {
            will-change: transform;
        }

        /* =========================================================
           14. RESPONSIVE – TABLET & MOBILE
        ========================================================== */

        @@media (max-width: 991.98px) {
            .news-page .section-title {
                font-size: 1.4rem;
            }

            .news-page .row > .col-lg-8 {
                margin-bottom: 1.8rem;
            }

            .news-page aside .sticky-top {
                position: static;
            }
        }

        @@media (max-width: 767.98px) {
            .news-page {
                padding-top: 1.2rem;
            }

                .news-page .section-title::before {
                    width: 28px;
                    height: 28px;
                }

            .news-thumb {
                height: 170px;
            }

            .news-card .card-body {
                padding: .9rem .9rem 1rem;
            }

            .news-page .pagination {
                gap: .25rem;
            }

            .news-page .page-item .page-link {
                min-width: 2.2rem;
                height: 2.2rem;
                font-size: .8rem;
            }

            .news-page aside .card-body {
                padding-inline: .9rem;
            }

            .news-page .list-group-item {
                padding-inline: .1rem;
            }
        }

        @@media (max-width: 575.98px) {
            .news-page .container::before {
                opacity: 0.9;
            }

            .news-thumb {
                height: 160px;
            }

            .news-card {
                border-radius: 1rem;
            }

            .news-page .breadcrumb {
                max-width: 100%;
                margin-top: .6rem;
            }
        }
    </style>
}


    </div>
</div>

<script>
    function stepQty(delta) {
        const ip = document.getElementById('qty');
        let v = parseInt(ip.value || '1', 10) + delta;
        if (v < 1) v = 1;
        ip.value = v;
    }
    document.addEventListener('click', function (e) {
        const card = e.target.closest('.clickable-related');
        if (!card) return;

        // Không click khi bấm nút trái tim
        if (e.target.closest('.related-fav-btn')) return;

        const url = card.dataset.url;
        if (url) window.location.href = url;
    });
</script>
